SLOTTET_DB_CONNECTION=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=Slottet;Persist Security Info=False;User ID=your-user;Password=your-password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
SLOTTET_JWT_SIGNING_KEY=ChangeThis_JwtSigningKey_AtLeast32Chars_Long
SLOTTET_JWT_ISSUER=Slottet.Api
SLOTTET_JWT_AUDIENCE=Slottet.Web
SLOTTET_JWT_EXPIRATION_MINUTES=60
SLOTTET_SWAGGER_ENABLED=true
SLOTTET_REVERSE_PROXY_ENABLED=false
SLOTTET_LOG_RETENTION_ENABLED=true
SLOTTET_LOG_RETENTION_AUDIT_DAYS=180
SLOTTET_LOG_RETENTION_ACCESS_DAYS=90
SLOTTET_API_BASEURL=http://api:8080/
SLOTTET_DATAPROTECTION_APPNAME=Slottet
SLOTTET_WEB_ORIGIN_HTTP=http://localhost:8080
SLOTTET_WEB_ORIGIN_HTTPS=https://localhost:8443
