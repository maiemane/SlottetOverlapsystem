@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<div class="page @(AuthService.IsAuthenticated ? "page-authenticated" : "page-guest")">
    @if (AuthService.IsAuthenticated)
    {
        <div class="top-row px-4">
            <div class="session-meta">
                <span class="session-role">@AuthService.CurrentUser?.Role</span>
                <strong>@AuthService.CurrentUser?.FullName</strong>
            </div>
            <div class="top-actions">
                <label class="department-select">
                    <span>Afdeling</span>
                    <select value="@AuthService.SelectedDepartment" @onchange="HandleDepartmentChanged">
                        @foreach (var department in AuthService.Departments)
                        {
                            <option value="@department">@department</option>
                        }
                    </select>
                </label>
                <label class="department-select">
                    <span>Vagt</span>
                    <select value="@AuthService.SelectedShift" @onchange="HandleShiftChanged">
                        @foreach (var shift in AuthService.Shifts)
                        {
                            <option value="@shift">@shift</option>
                        }
                    </select>
                </label>
                <button type="button" class="btn btn-link logout-link" @onclick="Logout">
                    Log ud
                </button>
            </div>
        </div>
    }

    <div class="page-body">
        @if (CanSeeSidebar)
        {
            <aside class="admin-sidebar @(IsSidebarOpen ? "open" : "closed")">
                <button type="button" class="sidebar-edge-toggle" @onclick="ToggleSidebar" aria-label="Skift sidebar">
                    <span>@(IsSidebarOpen ? "‹" : "›")</span>
                </button>

                <nav class="admin-nav @(IsSidebarOpen ? string.Empty : "admin-nav-hidden")">
                    <div class="admin-nav-main">
                        <NavLink class="admin-nav-link" href="/app" Match="NavLinkMatch.All">Overlapssystem</NavLink>
                        <NavLink class="admin-nav-link" href="/app/borger-fordeling">Borgerfordeling</NavLink>
                        @if (IsAdmin)
                        {
                            <NavLink class="admin-nav-link" href="/admin/opret-borger">Opret Borger</NavLink>
                            <NavLink class="admin-nav-link" href="/admin/opret-medarbejder">Opret Medarbejder</NavLink>
                            <NavLink class="admin-nav-link" href="/admin/historik">Søg i historik</NavLink>
                            <NavLink class="admin-nav-link" href="/admin/logs">Logs & GDPR</NavLink>
                        }
                    </div>

                    @if (IsAdmin)
                    {
                        <div class="admin-nav-bottom">
                            <NavLink class="admin-nav-link" href="/admin/konfiguration">Konfiguration</NavLink>
                        </div>
                    }
                </nav>
            </aside>
        }

        <main>
            <article class="content @(AuthService.IsAuthenticated ? "content-authenticated px-4" : "content-guest")">
                @Body
            </article>
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool IsSidebarOpen { get; set; } = true;

    private bool IsAdmin => AuthService.CurrentUser?.Role == "Admin";
    private bool IsVagtansvarlig => AuthService.CurrentUser?.Role == "Vagtansvarlig";
    private bool CanSeeSidebar => IsAdmin || IsVagtansvarlig;

    protected override void OnInitialized()
    {
        AuthService.AuthenticationStateChanged += HandleAuthenticationStateChanged;
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }

    private void HandleAuthenticationStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleDepartmentChanged(ChangeEventArgs e)
    {
        var department = e.Value?.ToString();

        if (!string.IsNullOrWhiteSpace(department))
        {
            AuthService.SetSelectedDepartment(department);
        }
    }

    private void ToggleSidebar()
    {
        IsSidebarOpen = !IsSidebarOpen;
    }

    private void HandleShiftChanged(ChangeEventArgs e)
    {
        var shift = e.Value?.ToString();

        if (!string.IsNullOrWhiteSpace(shift))
        {
            AuthService.SetSelectedShift(shift);
        }
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/", replace: true);
    }
}
