        padding: 2rem 0 3rem;
        color: #19352c;
        display: grid;
        gap: 1rem;
    }

    .config-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .config-header h1 {
        margin: 0;
    }

    .config-header p {
        margin: 0.35rem 0 0;
        color: #5d7469;
    }

    .config-card {
        border: 1px solid #d6e2da;
        border-radius: 1rem;
        background: #fff;
        padding: 1rem;
        box-shadow: 0 8px 20px rgba(34, 63, 50, 0.06);
    }

    .config-card h2 {
        margin: 0;
        font-size: 1.1rem;
    }

    .config-card-header {
        display: flex;
        justify-content: space-between;
        gap: 0.9rem;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .config-actions {
        display: flex;
        gap: 0.6rem;
    }

    .config-muted {
        margin: 0.4rem 0 1rem;
        color: #60786c;
    }

    .config-subheading {
        margin: 0 0 0.75rem;
        font-size: 0.95rem;
        color: #2f4f42;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .config-subheading-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .config-subheading-row .config-subheading {
        margin: 0;
    }

    .config-subheading-phones {
        padding-top: 0.9rem;
    }

    .config-grid {
        display: grid;
        gap: 0.75rem;
    }

    .config-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem;
        border: 1px solid #e0e9e4;
        border-radius: 0.75rem;
        background: #f8fbf9;
    }

    .config-row-fields {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    .config-row label,
    .config-row span {
        font-size: 0.82rem;
        font-weight: 700;
        color: #486257;
    }

    .config-row input {
        padding: 0.45rem 0.6rem;
        border: 1px solid #bfd1c4;
        border-radius: 0.65rem;
        background: #fff;
    }

    .config-row-disclaimer {
        display: grid;
        gap: 0.45rem;
        align-items: stretch;
    }

    .config-textarea-label {
        display: flex;
    }

    .config-textarea {
        width: 100%;
        min-height: 4.5rem;
        padding: 0.6rem 0.75rem;
        border: 1px solid #bfd1c4;
        border-radius: 0.65rem;
