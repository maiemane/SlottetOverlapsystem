@page "/admin/konfiguration"
@using System.Net
@using System.Net.Http.Json
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<PageTitle>Konfiguration</PageTitle>

@if (IsAdmin)
{
    <section class="config-shell">
        <header class="config-header">
            <div>
                <h1>Konfiguration</h1>
                <p>Fælles opsætning af systemet.</p>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert @(HasValidationError ? "alert-danger" : "alert-success")" role="alert">@StatusMessage</div>
        }

        <section class="config-card">
            <div class="config-card-header">
                <div>
                    <h2>Disclaimer bar</h2>
                    <p class="config-muted">Teksten vises i toppen af siden og afhænger af valgt afdeling.</p>
                </div>
                <div class="config-actions">
                    <button type="button" class="btn btn-outline-secondary" @onclick="ResetDisclaimersAsync" disabled="@(IsSavingDisclaimers || IsLoadingDisclaimers)">Nulstil</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveDisclaimersAsync" disabled="@(IsSavingDisclaimers || IsLoadingDisclaimers)">
                        @(IsSavingDisclaimers ? "Gemmer..." : "Gem disclaimer")
                    </button>
                </div>
            </div>

            @if (IsLoadingDisclaimers)
            {
                <p>Indlæser afdelingsbeskeder...</p>
            }
            else
            {
                <div class="config-grid">
                    <div class="config-row config-row-disclaimer">
                        <label class="config-textarea-label" for="slottet-disclaimer">
                            <span>Slottet disclaimer</span>
                        </label>
                        <textarea
                            id="slottet-disclaimer"
                            class="config-textarea"
                            rows="3"
                            @bind="SlottetDisclaimerText"
                            @bind:event="oninput"
                            placeholder="Skriv disclaimer for Slottet..."></textarea>
                    </div>
                    <div class="config-row config-row-disclaimer">
                        <label class="config-textarea-label" for="skoven-disclaimer">
                            <span>Skoven disclaimer</span>
                        </label>
                        <textarea
                            id="skoven-disclaimer"
                            class="config-textarea"
                            rows="3"
                            @bind="SkovenDisclaimerText"
                            @bind:event="oninput"
                            placeholder="Skriv disclaimer for Skoven..."></textarea>
                    </div>
                </div>
            }
        </section>

        <section class="config-card">
            <div class="config-card-header">
                <div>
                    <h2>Vagtkonfiguration</h2>
                    <p class="config-muted">Nattevagt kan krydse midnat (fx 23:00 til 07:00).</p>
                </div>
                <div class="config-actions">
                    <button type="button" class="btn btn-outline-secondary" @onclick="ResetToDatabaseAsync" disabled="@IsSaving">Nulstil</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveChangesAsync" disabled="@(IsSaving || ShiftRows.Count == 0)">
                        @(IsSaving ? "Gemmer..." : "Gem ændringer")
                    </button>
                </div>
            </div>

            <h3 class="config-subheading">Tidsintervaller</h3>

            @if (IsLoading)
            {
                <p>Indlæser vagtdefinitioner...</p>
            }
            else
            {
            <div class="config-grid">
                @for (var index = 0; index < ShiftRows.Count; index++)
                {
                    var row = ShiftRows[index];
                    var rowIndex = index;
                    <div class="config-row">
                        <strong>@row.Label</strong>
                        <div class="config-row-fields">
                            <label>
                                <span>Fra</span>
                                <input type="time" value="@row.StartTimeText" @onchange="args => HandleStartChanged(rowIndex, args)" />
                            </label>
                            <label>
                                <span>Til</span>
                                <input type="time" value="@row.EndTimeText" @onchange="args => HandleEndChanged(rowIndex, args)" />
                            </label>
                        </div>
                    </div>
                }
            </div>
            }
        </section>

        <section class="config-card">
            <div class="config-card-header">
                <div>
                    <h2>Telefoner</h2>
                    <p class="config-muted">Administrer telefoner der kan fordeles på vagter.</p>
                </div>
                <div class="config-actions">
                    <button type="button" class="btn btn-outline-secondary" @onclick="ResetPhonesAsync" disabled="@(IsLoadingPhones || IsSavingPhones || IsCreatingPhone || DeletingPhoneIds.Count > 0)">Nulstil</button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(PhoneStatusMessage))
            {
                <div class="alert @(HasPhoneValidationError ? "alert-danger" : "alert-success")" role="alert">@PhoneStatusMessage</div>
            }

            <div class="config-subheading-row">
                <h3 class="config-subheading">Tilføj telefon</h3>
                <button type="button" class="btn btn-primary btn-sm" @onclick="CreatePhoneAsync" disabled="@(IsCreatingPhone || IsLoadingPhones)">@(IsCreatingPhone ? "Opretter..." : "Opret")</button>
            </div>

            <div class="config-row config-row-phone-create">
                <label for="new-phone-name">Navn/nummer</label>
                <InputText id="new-phone-name"
                           class="form-control"
                           @bind-Value="NewPhoneNameOrNumber"
                           disabled="@(IsCreatingPhone || IsLoadingPhones)" />
                <label class="config-checkbox">
                    <InputCheckbox @bind-Value="NewPhoneIsActive" disabled="@(IsCreatingPhone || IsLoadingPhones)" />
                    <span>Aktiv</span>
                </label>
            </div>

            <h3 class="config-subheading config-subheading-phones">Eksisterende telefoner</h3>
            @if (IsLoadingPhones)
            {
                <p>Indlæser telefoner...</p>
            }
            else if (PhoneRows.Count == 0)
            {
                <p>Ingen telefoner oprettet endnu.</p>
            }
            else
            {
                <div class="config-grid">
                    @foreach (var phone in PhoneRows)
                    {
                        <div class="config-row config-row-phone">
                            <div class="config-row-phone-fields">
                                <InputText class="form-control"
                                           @bind-Value="phone.NameOrNumber"
                                           disabled="@(IsSavingPhones || IsLoadingPhones || DeletingPhoneIds.Contains(phone.Id))" />
                                <label class="config-checkbox">
                                    <InputCheckbox @bind-Value="phone.IsActive" disabled="@(IsSavingPhones || IsLoadingPhones || DeletingPhoneIds.Contains(phone.Id))" />
                                    <span>Aktiv</span>
                                </label>
                            </div>
                            <div class="config-actions">
                                <button type="button"
                                        class="btn btn-sm btn-primary"
                                        @onclick="() => SavePhoneAsync(phone)"
                                        disabled="@(IsSavingPhones || IsLoadingPhones || DeletingPhoneIds.Contains(phone.Id))">
                                    Gem
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        @onclick="() => DeletePhoneAsync(phone)"
                                        disabled="@(IsSavingPhones || IsLoadingPhones || DeletingPhoneIds.Contains(phone.Id))">
                                    @(DeletingPhoneIds.Contains(phone.Id) ? "Sletter..." : "Slet")
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </section>
}

<style>
