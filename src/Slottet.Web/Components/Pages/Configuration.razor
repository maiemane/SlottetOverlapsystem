</style>

@code {
    private bool IsAdmin => AuthService.CurrentUser?.Role == "Admin";

    private List<ShiftConfigRow> ShiftRows { get; set; } = [];
    private List<ShiftConfigRow> InitialShiftRows { get; set; } = [];
    private string? StatusMessage { get; set; }
    private bool HasValidationError { get; set; }
    private bool IsLoading { get; set; }
    private bool IsLoadingDisclaimers { get; set; }
    private bool IsSaving { get; set; }
    private bool IsSavingDisclaimers { get; set; }
    private bool IsLoadingPhones { get; set; }
    private bool IsSavingPhones { get; set; }
    private bool IsCreatingPhone { get; set; }
    private string SlottetDisclaimerText { get; set; } = string.Empty;
    private string SkovenDisclaimerText { get; set; } = string.Empty;
    private string? PhoneStatusMessage { get; set; }
    private bool HasPhoneValidationError { get; set; }
    private string NewPhoneNameOrNumber { get; set; } = string.Empty;
    private bool NewPhoneIsActive { get; set; } = true;
    private List<PhoneRow> PhoneRows { get; set; } = [];
    private HashSet<int> DeletingPhoneIds { get; } = [];
    private int? SlottetDepartmentId { get; set; }
    private int? SkovenDepartmentId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!IsAdmin)
        {
            NavigationManager.NavigateTo("/app", replace: true);
            return;
        }

        await LoadShiftDefinitionsAsync();
        await LoadDisclaimersAsync();
        await LoadPhonesAsync();
    }

    private async Task SaveDisclaimersAsync()
    {
        try
        {
            IsSavingDisclaimers = true;
            HasValidationError = false;

            if (SlottetDepartmentId is null || SkovenDepartmentId is null)
            {
                HasValidationError = true;
                StatusMessage = "Kunne ikke gemme: afdelingerne blev ikke fundet.";
                return;
            }

            var client = AuthService.CreateApiClient();

            using var slottetResponse = await client.PutAsJsonAsync(
                $"api/departments/{SlottetDepartmentId.Value}/message",
                new UpdateDepartmentMessageRequestApiModel { Message = SlottetDisclaimerText.Trim() });

            if (!slottetResponse.IsSuccessStatusCode)
            {
                var apiMessage = await slottetResponse.Content.ReadAsStringAsync();
                HasValidationError = true;
                StatusMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? $"Kunne ikke gemme disclaimer for Slottet. HTTP {(int)slottetResponse.StatusCode}."
                    : apiMessage;
                return;
            }

            using var skovenResponse = await client.PutAsJsonAsync(
                $"api/departments/{SkovenDepartmentId.Value}/message",
                new UpdateDepartmentMessageRequestApiModel { Message = SkovenDisclaimerText.Trim() });

            if (!skovenResponse.IsSuccessStatusCode)
            {
                var apiMessage = await skovenResponse.Content.ReadAsStringAsync();
                HasValidationError = true;
                StatusMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? $"Kunne ikke gemme disclaimer for Skoven. HTTP {(int)skovenResponse.StatusCode}."
                    : apiMessage;
                return;
            }

            await LoadDisclaimersAsync();

            StatusMessage = "Afdelingsbeskeder er opdateret.";
        }
        catch (HttpRequestException)
        {
            HasValidationError = true;
            StatusMessage = "Kunne ikke kontakte API'et for afdelingsbeskeder.";
        }
        finally
        {
            IsSavingDisclaimers = false;
        }
    }

    private async Task ResetDisclaimersAsync()
    {
        if (IsSavingDisclaimers)
        {
            return;
        }

        await LoadDisclaimersAsync();

        if (!HasValidationError)
        {
            StatusMessage = "Afdelingsbeskeder er genindlæst.";
        }
    }

    private async Task LoadDisclaimersAsync()
    {
        try
        {
            IsLoadingDisclaimers = true;
            HasValidationError = false;

            var client = AuthService.CreateApiClient();
            using var response = await client.GetAsync("api/departments");

            if (!response.IsSuccessStatusCode)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                HasValidationError = true;
                StatusMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke hente afdelingsbeskeder."
                    : apiMessage;
                return;
            }

            var departments = await response.Content.ReadFromJsonAsync<List<DepartmentApiModel>>() ?? [];
            var slottetDepartment = departments.FirstOrDefault(department => string.Equals(department.Name, "Slottet", StringComparison.OrdinalIgnoreCase));
            var skovenDepartment = departments.FirstOrDefault(department => string.Equals(department.Name, "Skoven", StringComparison.OrdinalIgnoreCase));

            SlottetDepartmentId = slottetDepartment?.Id;
            SkovenDepartmentId = skovenDepartment?.Id;
            SlottetDisclaimerText = slottetDepartment?.Message ?? string.Empty;
            SkovenDisclaimerText = skovenDepartment?.Message ?? string.Empty;
        }
        catch (HttpRequestException)
        {
            HasValidationError = true;
            StatusMessage = "Kunne ikke hente afdelingsbeskeder fra API'et.";
        }
        finally
        {
            IsLoadingDisclaimers = false;
        }
    }

    private void HandleStartChanged(int index, ChangeEventArgs args)
    {
        if (index < 0 || index >= ShiftRows.Count)
        {
            return;
        }

        var newStart = args.Value?.ToString() ?? string.Empty;
        ShiftRows[index].StartTimeText = newStart;

        var previousIndex = GetWrappedIndex(index - 1);

        if (previousIndex >= 0)
        {
            ShiftRows[previousIndex].EndTimeText = newStart;
        }
    }

    private void HandleEndChanged(int index, ChangeEventArgs args)
    {
        if (index < 0 || index >= ShiftRows.Count)
        {
            return;
        }

        var newEnd = args.Value?.ToString() ?? string.Empty;
        ShiftRows[index].EndTimeText = newEnd;

        var nextIndex = GetWrappedIndex(index + 1);

        if (nextIndex >= 0)
        {
            ShiftRows[nextIndex].StartTimeText = newEnd;
        }
    }

    private int GetWrappedIndex(int rawIndex)
    {
        if (ShiftRows.Count == 0)
        {
            return -1;
        }

        var wrapped = rawIndex % ShiftRows.Count;

        if (wrapped < 0)
        {
            wrapped += ShiftRows.Count;
        }

        return wrapped;
    }

    private async Task SaveChangesAsync()
    {
        if (!TryBuildResolvedRows(out var rows, out var validationMessage))
        {
            HasValidationError = true;
            StatusMessage = validationMessage;
            return;
        }

        var overlapPair = FindOverlap(rows);

        if (overlapPair is not null)
        {
            HasValidationError = true;
            StatusMessage = $"Intervaller overlapper mellem {overlapPair.Value.First} og {overlapPair.Value.Second}.";
            return;
        }

        try
        {
            IsSaving = true;
            HasValidationError = false;
            StatusMessage = null;

            var client = AuthService.CreateApiClient();
            var changedRows = ShiftRows
                .Where(row =>
                {
                    var original = InitialShiftRows.FirstOrDefault(initial => initial.Id == row.Id);
                    return original is null
                        || !string.Equals(original.StartTimeText, row.StartTimeText, StringComparison.Ordinal)
                        || !string.Equals(original.EndTimeText, row.EndTimeText, StringComparison.Ordinal)
                        || original.IsActive != row.IsActive;
                })
                .ToList();

            if (changedRows.Count == 0)
            {
                StatusMessage = "Ingen ændringer at gemme.";
                return;
            }

            var pendingRows = new List<ShiftConfigRow>(changedRows);
            var progress = true;

            while (pendingRows.Count > 0 && progress)
            {
                progress = false;
                var nextPending = new List<ShiftConfigRow>();

                foreach (var row in pendingRows)
                {
                    if (!TimeOnly.TryParse(row.StartTimeText, out var startTime) || !TimeOnly.TryParse(row.EndTimeText, out var endTime))
                    {
                        HasValidationError = true;
                        StatusMessage = $"Kunne ikke gemme {row.Label} pga. ugyldigt tidspunkt.";
                        return;
                    }

                    using var response = await client.PutAsJsonAsync(
                        $"api/shift-definitions/{row.Id}",
                        new
                        {
                            shiftType = row.ShiftType,
                            startTime,
                            endTime,
                            isActive = row.IsActive
                        });

                    if (response.IsSuccessStatusCode)
                    {
                        progress = true;
                        continue;
                    }

                    var apiMessage = await response.Content.ReadAsStringAsync();
                    var isScheduleConflict = response.StatusCode == HttpStatusCode.BadRequest
                        && apiMessage.Contains("overlapper", StringComparison.OrdinalIgnoreCase);

                    if (isScheduleConflict)
                    {
                        nextPending.Add(row);
                        continue;
                    }

                    HasValidationError = true;
                    StatusMessage = string.IsNullOrWhiteSpace(apiMessage)
                        ? $"Kunne ikke gemme {row.Label}. HTTP {(int)response.StatusCode}."
                        : apiMessage;
                    return;
                }

                pendingRows = nextPending;
            }

            if (pendingRows.Count > 0)
            {
                HasValidationError = true;
                StatusMessage = "Kunne ikke gemme alle vagtdefinitioner i gyldig rækkefølge. Prøv igen.";
                return;
            }

            HasValidationError = false;
            StatusMessage = "Vagtdefinitioner er opdateret.";
            await LoadShiftDefinitionsAsync();
        }
        catch (HttpRequestException)
        {
            HasValidationError = true;
            StatusMessage = "Kunne ikke kontakte API'et for vagtdefinitioner.";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task ResetToDatabaseAsync()
    {
        if (IsSaving)
        {
            return;
        }

        await LoadShiftDefinitionsAsync();

        if (!HasValidationError)
        {
            StatusMessage = "Værdier genindlæst fra databasen.";
        }
    }

    private bool TryBuildResolvedRows(out List<ResolvedShiftRow> rows, out string? error)
    {
        rows = new List<ResolvedShiftRow>(ShiftRows.Count);

        foreach (var row in ShiftRows)
        {
            if (!TimeOnly.TryParse(row.StartTimeText, out var startTime))
            {
                error = $"Ugyldigt starttidspunkt for {row.Label}.";
                return false;
            }

            if (!TimeOnly.TryParse(row.EndTimeText, out var endTime))
            {
                error = $"Ugyldigt sluttidspunkt for {row.Label}.";
                return false;
            }

            if (startTime == endTime)
            {
                error = $"{row.Label} kan ikke have samme start- og sluttid.";
                return false;
            }

            rows.Add(new ResolvedShiftRow(row.Label, startTime, endTime));
        }

        error = null;
        return true;
    }

    private static (string First, string Second)? FindOverlap(IReadOnlyList<ResolvedShiftRow> rows)
    {
        for (var minute = 0; minute < 24 * 60; minute++)
        {
            var candidate = TimeOnly.FromTimeSpan(TimeSpan.FromMinutes(minute));
            var matches = rows.Where(entry => TimeInRange(candidate, entry.StartTime, entry.EndTime)).ToList();
            if (matches.Count > 1)
            {
                return (matches[0].Label, matches[1].Label);
            }
        }

        return null;
    }

    private static bool TimeInRange(TimeOnly value, TimeOnly start, TimeOnly end)
    {
        return start <= end
            ? value >= start && value < end
            : value >= start || value < end;
    }

    private async Task LoadShiftDefinitionsAsync()
    {
        try
        {
            IsLoading = true;
            StatusMessage = null;
            HasValidationError = false;

            var client = AuthService.CreateApiClient();
            using var response = await client.GetAsync("api/shift-definitions");

            if (!response.IsSuccessStatusCode)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                HasValidationError = true;
                StatusMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke hente vagtdefinitioner."
                    : apiMessage;
                ShiftRows = [];
                InitialShiftRows = [];
                return;
            }

            var definitions = await response.Content.ReadFromJsonAsync<List<ShiftDefinitionApiModel>>() ?? [];
            ShiftRows = definitions
                .OrderBy(definition => definition.ShiftType)
                .Select(definition => new ShiftConfigRow(
                    definition.Id,
                    definition.ShiftType,
                    GetShiftTypeLabel(definition.ShiftType),
                    definition.StartTime.ToString("HH\\:mm"),
                    definition.EndTime.ToString("HH\\:mm"),
                    definition.IsActive))
                .ToList();
            InitialShiftRows = CloneRows(ShiftRows);
        }
        catch (HttpRequestException)
        {
            HasValidationError = true;
            StatusMessage = "Kunne ikke hente vagtdefinitioner fra API'et.";
            ShiftRows = [];
            InitialShiftRows = [];
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadPhonesAsync()
    {
        try
        {
            IsLoadingPhones = true;
            HasPhoneValidationError = false;
            PhoneStatusMessage = null;

            var client = AuthService.CreateApiClient();
            using var response = await client.GetAsync("api/phones");

            if (!response.IsSuccessStatusCode)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                HasPhoneValidationError = true;
                PhoneStatusMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke hente telefoner."
                    : apiMessage;
                PhoneRows = [];
                return;
            }

            var phones = await response.Content.ReadFromJsonAsync<List<PhoneApiModel>>() ?? [];
            PhoneRows = phones
                .OrderBy(phone => phone.NameOrNumber, StringComparer.OrdinalIgnoreCase)
                .Select(phone => new PhoneRow
                {
                    Id = phone.Id,
                    NameOrNumber = phone.NameOrNumber,
                    IsActive = phone.IsActive
                })
                .ToList();
        }
        catch (HttpRequestException)
        {
            HasPhoneValidationError = true;
            PhoneStatusMessage = "Kunne ikke hente telefoner fra API'et.";
            PhoneRows = [];
        }
        finally
        {
            IsLoadingPhones = false;
        }
    }

    private async Task ResetPhonesAsync()
    {
        if (IsLoadingPhones || IsSavingPhones || IsCreatingPhone || DeletingPhoneIds.Count > 0)
        {
            return;
        }

        await LoadPhonesAsync();

        if (!HasPhoneValidationError)
        {
            PhoneStatusMessage = "Telefoner er genindlæst.";
        }
    }

    private async Task CreatePhoneAsync()
    {
        if (string.IsNullOrWhiteSpace(NewPhoneNameOrNumber))
        {
            HasPhoneValidationError = true;
            PhoneStatusMessage = "Navn/nummer er påkrævet.";
            return;
        }

        try
        {
            IsCreatingPhone = true;
            HasPhoneValidationError = false;
            PhoneStatusMessage = null;

            var client = AuthService.CreateApiClient();
            using var response = await client.PostAsJsonAsync(
                "api/phones",
                new
                {
                    nameOrNumber = NewPhoneNameOrNumber.Trim(),
                    isActive = NewPhoneIsActive
                });

            if (!response.IsSuccessStatusCode)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                HasPhoneValidationError = true;
                PhoneStatusMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke oprette telefonen."
                    : apiMessage;
                return;
            }

            NewPhoneNameOrNumber = string.Empty;
            NewPhoneIsActive = true;
            await LoadPhonesAsync();
            PhoneStatusMessage = "Telefonen er oprettet.";
        }
        catch (HttpRequestException)
        {
            HasPhoneValidationError = true;
            PhoneStatusMessage = "Kunne ikke oprette telefon via API'et.";
        }
        finally
        {
            IsCreatingPhone = false;
        }
    }

    private async Task SavePhoneAsync(PhoneRow row)
    {
        if (row.Id <= 0)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(row.NameOrNumber))
        {
            HasPhoneValidationError = true;
            PhoneStatusMessage = "Navn/nummer er påkrævet.";
            return;
        }

        try
        {
            IsSavingPhones = true;
            HasPhoneValidationError = false;
            PhoneStatusMessage = null;

            var client = AuthService.CreateApiClient();
            using var response = await client.PutAsJsonAsync(
                $"api/phones/{row.Id}",
                new
                {
                    nameOrNumber = row.NameOrNumber.Trim(),
                    isActive = row.IsActive
                });

            if (!response.IsSuccessStatusCode)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                HasPhoneValidationError = true;
                PhoneStatusMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke gemme telefonen."
                    : apiMessage;
                return;
            }

            await LoadPhonesAsync();
            PhoneStatusMessage = "Telefonen er opdateret.";
        }
        catch (HttpRequestException)
        {
            HasPhoneValidationError = true;
            PhoneStatusMessage = "Kunne ikke gemme telefon via API'et.";
        }
        finally
        {
            IsSavingPhones = false;
        }
    }

    private async Task DeletePhoneAsync(PhoneRow row)
    {
        if (row.Id <= 0 || DeletingPhoneIds.Contains(row.Id))
        {
            return;
        }

        DeletingPhoneIds.Add(row.Id);
        HasPhoneValidationError = false;
        PhoneStatusMessage = null;

        try
        {
            var client = AuthService.CreateApiClient();
            using var response = await client.DeleteAsync($"api/phones/{row.Id}");

            if (!response.IsSuccessStatusCode)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                HasPhoneValidationError = true;
                PhoneStatusMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke slette telefonen."
                    : apiMessage;
                return;
            }

            await LoadPhonesAsync();
            PhoneStatusMessage = "Telefonen er slettet.";
        }
        catch (HttpRequestException)
        {
            HasPhoneValidationError = true;
            PhoneStatusMessage = "Kunne ikke slette telefon via API'et.";
        }
        finally
        {
            DeletingPhoneIds.Remove(row.Id);
        }
    }

    private static List<ShiftConfigRow> CloneRows(IEnumerable<ShiftConfigRow> source)
    {
        return source
            .Select(row => new ShiftConfigRow(row.Id, row.ShiftType, row.Label, row.StartTimeText, row.EndTimeText, row.IsActive))
            .ToList();
    }

    private static string GetShiftTypeLabel(int shiftType)
    {
        return shiftType switch
        {
            1 => "Dagvagt",
            2 => "Aftenvagt",
            3 => "Nattevagt",
            _ => $"Vagt {shiftType}"
        };
    }

