@page "/admin/opret-borger"
@using System.ComponentModel.DataAnnotations
@using System.Net
@using System.Net.Http.Json
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<PageTitle>Opret Borger</PageTitle>

@if (IsAdmin)
{
    <section class="p-4">
        <h1>Opret Borger</h1>
        <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
            <h2 class="h4 mb-0">Borgere</h2>
            <button type="button" class="btn btn-primary" @onclick="ShowCreateForm">
                Tilføj borger
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(SuccessMessage))
        {
            <div class="alert alert-success" role="alert">@SuccessMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(LoadErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@LoadErrorMessage</div>
        }
        else if (IsLoadingCitizens)
        {
            <p>Indlæser borgere...</p>
        }
        else if (Citizens.Count == 0)
        {
            <p>Der er ingen borgere endnu.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Navn</th>
                            <th>Lejlighed</th>
                            <th>Trafiklys</th>
                            <th>Afdeling</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var citizen in Citizens)
                        {
                            <tr>
                                <td>@citizen.Name</td>
                                <td>@citizen.ApartmentNumber</td>
                                <td>@GetTrafficLightLabel(citizen.TrafficLight)</td>
                                <td>@GetDepartmentName(citizen.DepartmentId)</td>
                                <td>@(citizen.IsActive ? "Aktiv" : "Inaktiv")</td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-outline-primary btn-sm me-2" @onclick="@(() => ShowEditFormAsync(citizen))">
                                        Rediger
                                    </button>
                                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="@(() => PromptDelete(citizen))">
                                        Slet
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (IsCreateFormVisible)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h2 class="modal-title h5 mb-0">Ny borger</h2>
                            <button type="button" class="btn-close" aria-label="Close" @onclick="HideCreateForm"></button>
                        </div>
                        <div class="modal-body">
                            <EditForm Model="@Model" OnValidSubmit="@HandleSubmitAsync">
                                <DataAnnotationsValidator />

                                <div class="mb-3">
                                    <label class="form-label" for="citizen-name">Navn</label>
                                    <InputText id="citizen-name" class="form-control" @bind-Value="Model.Name" />
                                    <ValidationMessage For="@(() => Model.Name)" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label" for="citizen-apartment-number">Lejlighedsnummer</label>
                                    <InputText id="citizen-apartment-number" class="form-control" @bind-Value="Model.ApartmentNumber" />
                                    <ValidationMessage For="@(() => Model.ApartmentNumber)" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label" for="citizen-traffic-light">Trafiklys</label>
                                    <InputSelect id="citizen-traffic-light" class="form-select" @bind-Value="Model.TrafficLight">
                                        <option value="0">Vælg trafiklys</option>
                                        @foreach (var option in TrafficLightOptions)
                                        {
                                            <option value="@option.Value">@option.Label</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => Model.TrafficLight)" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label" for="citizen-department">Afdeling</label>
                                    <InputSelect id="citizen-department" class="form-select" @bind-Value="Model.DepartmentId">
                                        @foreach (var option in DepartmentOptions)
                                        {
                                            <option value="@option.Id">@option.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => Model.DepartmentId)" />
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <label class="form-label mb-0">Faste mediciner</label>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AddCreateFixedMedication" disabled="@IsSubmitting">
                                            Tilføj medicin
                                        </button>
                                    </div>

                                    @if (CreateFixedMedications.Count == 0)
                                    {
                                        <p class="text-muted mb-0">Ingen faste mediciner tilføjet.</p>
                                    }
                                    else
                                    {
                                        @for (var index = 0; index < CreateFixedMedications.Count; index++)
                                        {
                                            var medication = CreateFixedMedications[index];
                                            var rowIndex = index;
                                            <div class="border rounded p-2 mb-2">
                                                <div class="mb-2">
                                                    <label class="form-label">Navn</label>
                                                    <input class="form-control" value="@medication.Name" @onchange="args => medication.Name = args.Value?.ToString() ?? string.Empty" />
                                                </div>
                                                <div class="mb-2">
                                                    <label class="form-label">Beskrivelse</label>
                                                    <textarea class="form-control" rows="2" @onchange="args => medication.Description = args.Value?.ToString() ?? string.Empty">@medication.Description</textarea>
                                                </div>
                                                <div class="row g-2">
                                                    <div class="col-12">
                                                        <label class="form-label">Klokkeslæt</label>
                                                        <input type="time" class="form-control" value="@medication.ScheduledTimeText" @onchange="args => medication.ScheduledTimeText = args.Value?.ToString() ?? string.Empty" />
                                                    </div>
                                                </div>
                                                <div class="text-end mt-2">
                                                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="@(() => RemoveCreateFixedMedication(rowIndex))" disabled="@IsSubmitting">
                                                        Fjern
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                                {
                                    <div class="alert alert-danger" role="alert">@ErrorMessage</div>
                                }

                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-outline-secondary" @onclick="HideCreateForm" disabled="@IsSubmitting">
                                        Annuller
                                    </button>
                                    <button type="submit" class="btn btn-primary" disabled="@IsSubmitting">
                                        @(IsSubmitting ? "Opretter..." : "Opret borger")
                                    </button>
                                </div>
                            </EditForm>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (CitizenBeingEdited is not null)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h2 class="modal-title h5 mb-0">Rediger borger</h2>
                            <button type="button" class="btn-close" aria-label="Close" @onclick="HideEditForm"></button>
                        </div>
                        <div class="modal-body">
                            <EditForm Model="@EditModel" OnValidSubmit="@HandleEditAsync">
                                <DataAnnotationsValidator />

                                <div class="mb-3">
                                    <label class="form-label" for="edit-citizen-name">Navn</label>
                                    <InputText id="edit-citizen-name" class="form-control" @bind-Value="EditModel.Name" />
                                    <ValidationMessage For="@(() => EditModel.Name)" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label" for="edit-citizen-apartment-number">Lejlighedsnummer</label>
                                    <InputText id="edit-citizen-apartment-number" class="form-control" @bind-Value="EditModel.ApartmentNumber" />
                                    <ValidationMessage For="@(() => EditModel.ApartmentNumber)" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label" for="edit-citizen-traffic-light">Trafiklys</label>
                                    <InputSelect id="edit-citizen-traffic-light" class="form-select" @bind-Value="EditModel.TrafficLight">
                                        <option value="0">Vælg trafiklys</option>
                                        @foreach (var option in TrafficLightOptions)
                                        {
                                            <option value="@option.Value">@option.Label</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => EditModel.TrafficLight)" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label" for="edit-citizen-department">Afdeling</label>
                                    <InputSelect id="edit-citizen-department" class="form-select" @bind-Value="EditModel.DepartmentId">
                                        @foreach (var option in DepartmentOptions)
                                        {
                                            <option value="@option.Id">@option.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => EditModel.DepartmentId)" />
                                </div>

                                <div class="form-check mb-3">
                                    <InputCheckbox id="edit-citizen-active" class="form-check-input" @bind-Value="EditModel.IsActive" />
                                    <label class="form-check-label" for="edit-citizen-active">Aktiv borger</label>
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <label class="form-label mb-0">Faste mediciner</label>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AddEditFixedMedication" disabled="@IsEditing">
                                            Tilføj medicin
                                        </button>
                                    </div>

                                    @if (IsLoadingEditFixedMedications)
                                    {
                                        <p class="text-muted mb-0">Indlæser faste mediciner...</p>
                                    }
                                    else if (EditFixedMedications.Count == 0)
                                    {
                                        <p class="text-muted mb-0">Ingen faste mediciner endnu.</p>
                                    }
                                    else
                                    {
                                        @for (var index = 0; index < EditFixedMedications.Count; index++)
                                        {
                                            var medication = EditFixedMedications[index];
                                            var rowIndex = index;
                                            <div class="border rounded p-2 mb-2">
                                                <div class="mb-2">
                                                    <label class="form-label">Navn</label>
                                                    <input class="form-control" value="@medication.Name" @onchange="args => medication.Name = args.Value?.ToString() ?? string.Empty" />
                                                </div>
                                                <div class="mb-2">
                                                    <label class="form-label">Beskrivelse</label>
                                                    <textarea class="form-control" rows="2" @onchange="args => medication.Description = args.Value?.ToString() ?? string.Empty">@medication.Description</textarea>
                                                </div>
                                                <div class="row g-2">
                                                    <div class="col-12">
                                                        <label class="form-label">Klokkeslæt</label>
                                                        <input type="time" class="form-control" value="@medication.ScheduledTimeText" @onchange="args => medication.ScheduledTimeText = args.Value?.ToString() ?? string.Empty" />
                                                    </div>
                                                </div>

                                                <div class="d-flex justify-content-between align-items-center mt-2">
                                                    <div class="form-check">
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               checked="@medication.IsActive"
                                                               @onchange="args => medication.IsActive = args.Value is bool isChecked && isChecked" />
                                                        <label class="form-check-label">Aktiv medicin</label>
                                                    </div>

                                                    @if (!medication.FixedMedicationId.HasValue)
                                                    {
                                                        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="@(() => RemoveEditFixedMedication(rowIndex))" disabled="@IsEditing">
                                                            Fjern
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(EditErrorMessage))
                                {
                                    <div class="alert alert-danger" role="alert">@EditErrorMessage</div>
                                }

                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-outline-secondary" @onclick="HideEditForm" disabled="@IsEditing">
                                        Annuller
                                    </button>
                                    <button type="submit" class="btn btn-primary" disabled="@IsEditing">
                                        @(IsEditing ? "Gemmer..." : "Gem ændringer")
                                    </button>
                                </div>
                            </EditForm>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (CitizenPendingDelete is not null)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5);">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h2 class="modal-title h5 mb-0">Bekræft sletning</h2>
                            <button type="button" class="btn-close" aria-label="Close" @onclick="CancelDelete"></button>
                        </div>
                        <div class="modal-body">
                            <p class="mb-0">Er du sikker på, at du vil slette @CitizenPendingDelete.Name?</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete" disabled="@IsDeleting">
                                Annuller
                            </button>
                            <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteAsync" disabled="@IsDeleting">
                                @(IsDeleting ? "Sletter..." : "Ja, slet")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </section>
}

@code {
    private static readonly IReadOnlyList<DepartmentOption> DepartmentOptions =
    [
        new(1, "Slottet"),
        new(2, "Skoven")
    ];

    private static readonly IReadOnlyList<TrafficLightOption> TrafficLightOptions =
    [
        new(1, "Grøn"),
        new(2, "Gul"),
        new(3, "Rød")
    ];

    private bool IsAdmin => AuthService.CurrentUser?.Role == "Admin";
    private List<CitizenListItem> Citizens { get; set; } = [];
    private CreateCitizenFormModel Model { get; set; } = new();
    private EditCitizenFormModel EditModel { get; set; } = new();
    private bool IsLoadingCitizens { get; set; }
    private bool IsSubmitting { get; set; }
    private bool IsEditing { get; set; }
    private bool IsDeleting { get; set; }
    private bool IsCreateFormVisible { get; set; }
    private string? ErrorMessage { get; set; }
    private string? EditErrorMessage { get; set; }
    private string? LoadErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }
    private CitizenListItem? CitizenBeingEdited { get; set; }
    private CitizenListItem? CitizenPendingDelete { get; set; }
    private List<FixedMedicationInputModel> CreateFixedMedications { get; set; } = [];
    private List<FixedMedicationInputModel> EditFixedMedications { get; set; } = [];
    private bool IsLoadingEditFixedMedications { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!IsAdmin)
        {
            NavigationManager.NavigateTo("/app", replace: true);
            return;
        }

        Model = CreateDefaultCreateModel();
        await LoadCitizensAsync();
    }

    private async Task HandleSubmitAsync()
    {
        IsSubmitting = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var client = AuthService.CreateApiClient();
            using var response = await client.PostAsJsonAsync("api/citizens", new
            {
                name = Model.Name.Trim(),
                apartmentNumber = Model.ApartmentNumber.Trim(),
                trafficLight = Model.TrafficLight,
                departmentId = Model.DepartmentId
            });

            if (response.IsSuccessStatusCode)
            {
                var createdCitizen = await response.Content.ReadFromJsonAsync<CitizenListItem>();
                var fixedMedicationErrors = new List<string>();

                if (createdCitizen?.Id > 0 && CreateFixedMedications.Count > 0)
                {
                    fixedMedicationErrors = await SaveCreateFixedMedicationsAsync(client, createdCitizen.Id);
                }

                SuccessMessage = fixedMedicationErrors.Count == 0
                    ? "Borgeren blev oprettet."
                    : $"Borgeren blev oprettet, men faste mediciner blev ikke gemt korrekt: {string.Join(" ", fixedMedicationErrors)}";
                Model = CreateDefaultCreateModel();
                CreateFixedMedications = [];
                await LoadCitizensAsync();
                IsCreateFormVisible = false;
                return;
            }

            if (response.StatusCode is HttpStatusCode.BadRequest or HttpStatusCode.NotFound)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                ErrorMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke oprette borgeren."
                    : apiMessage;
                return;
            }

            ErrorMessage = "Der opstod en fejl ved oprettelse af borgeren.";
        }
        catch (HttpRequestException)
        {
            ErrorMessage = "Kunne ikke kontakte API'et.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void ShowCreateForm()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        Model = CreateDefaultCreateModel();
        CreateFixedMedications = [];
        IsCreateFormVisible = true;
    }

    private void HideCreateForm()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        Model = CreateDefaultCreateModel();
        CreateFixedMedications = [];
        IsCreateFormVisible = false;
    }

    private async Task ShowEditFormAsync(CitizenListItem citizen)
    {
        SuccessMessage = null;
        EditErrorMessage = null;
        CitizenBeingEdited = citizen;
        EditModel = new EditCitizenFormModel
        {
            Name = citizen.Name,
            ApartmentNumber = citizen.ApartmentNumber,
            TrafficLight = citizen.TrafficLight,
            DepartmentId = citizen.DepartmentId,
            IsActive = citizen.IsActive
        };

        await LoadEditFixedMedicationsAsync(citizen.Id);
    }

    private void HideEditForm()
    {
        EditErrorMessage = null;
        CitizenBeingEdited = null;
        EditModel = new EditCitizenFormModel();
        EditFixedMedications = [];
        IsLoadingEditFixedMedications = false;
    }

    private async Task HandleEditAsync()
    {
        if (CitizenBeingEdited is null)
        {
            return;
        }

        IsEditing = true;
        EditErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var client = AuthService.CreateApiClient();
            using var response = await client.PutAsJsonAsync($"api/citizens/{CitizenBeingEdited.Id}", new
            {
                name = EditModel.Name.Trim(),
                apartmentNumber = EditModel.ApartmentNumber.Trim(),
                trafficLight = EditModel.TrafficLight,
                departmentId = EditModel.DepartmentId,
                isActive = EditModel.IsActive
            });

            if (response.IsSuccessStatusCode)
            {
                var fixedMedicationErrors = await SaveEditFixedMedicationsAsync(client, CitizenBeingEdited.Id);

                SuccessMessage = fixedMedicationErrors.Count == 0
                    ? "Borgeren blev opdateret."
                    : $"Borgeren blev opdateret, men nogle faste mediciner kunne ikke gemmes: {string.Join(" ", fixedMedicationErrors)}";
                await LoadCitizensAsync();
                HideEditForm();
                return;
            }

            if (response.StatusCode is HttpStatusCode.BadRequest or HttpStatusCode.NotFound)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                EditErrorMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke opdatere borgeren."
                    : apiMessage;
                return;
            }

            EditErrorMessage = "Der opstod en fejl ved opdatering af borgeren.";
        }
        catch (HttpRequestException)
        {
            EditErrorMessage = "Kunne ikke kontakte API'et.";
        }
        finally
        {
            IsEditing = false;
        }
    }

    private void PromptDelete(CitizenListItem citizen)
    {
        ErrorMessage = null;
        SuccessMessage = null;
        CitizenPendingDelete = citizen;
    }

    private void CancelDelete()
    {
        CitizenPendingDelete = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (CitizenPendingDelete is null)
        {
            return;
        }

        IsDeleting = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var client = AuthService.CreateApiClient();
            using var response = await client.DeleteAsync($"api/citizens/{CitizenPendingDelete.Id}");

            if (response.IsSuccessStatusCode)
            {
                SuccessMessage = "Borgeren blev slettet.";
                CitizenPendingDelete = null;
                await LoadCitizensAsync();
                return;
            }

            if (response.StatusCode is HttpStatusCode.NotFound or HttpStatusCode.Conflict or HttpStatusCode.BadRequest)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                ErrorMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke slette borgeren."
                    : apiMessage;
                return;
            }

            ErrorMessage = "Der opstod en fejl ved sletning af borgeren.";
        }
        catch (HttpRequestException)
        {
            ErrorMessage = "Kunne ikke kontakte API'et.";
        }
        finally
        {
            IsDeleting = false;
        }
    }

    private async Task LoadCitizensAsync()
    {
        IsLoadingCitizens = true;
        LoadErrorMessage = null;

        try
        {
            var client = AuthService.CreateApiClient();
            using var response = await client.GetAsync("api/citizens");

            if (response.IsSuccessStatusCode)
            {
                var citizens = await response.Content.ReadFromJsonAsync<List<CitizenListItem>>();
                Citizens = citizens ?? [];
                return;
            }

            var apiMessage = await response.Content.ReadAsStringAsync();
            LoadErrorMessage = string.IsNullOrWhiteSpace(apiMessage)
                ? $"Kunne ikke hente borgere fra API'et. HTTP {(int)response.StatusCode}."
                : $"Kunne ikke hente borgere fra API'et. HTTP {(int)response.StatusCode}: {apiMessage}";
        }
        catch (HttpRequestException)
        {
            LoadErrorMessage = "Kunne ikke hente borgere fra API'et.";
        }
        finally
        {
            IsLoadingCitizens = false;
        }
    }

    private async Task LoadEditFixedMedicationsAsync(int citizenId)
    {
        IsLoadingEditFixedMedications = true;
        EditFixedMedications = [];

        try
        {
            var client = AuthService.CreateApiClient();
            using var response = await client.GetAsync($"api/citizens/{citizenId}/fixed-medications");

            if (!response.IsSuccessStatusCode)
            {
                if (response.StatusCode != HttpStatusCode.NotFound)
                {
                    var apiMessage = await response.Content.ReadAsStringAsync();
                    EditErrorMessage = string.IsNullOrWhiteSpace(apiMessage)
                        ? "Kunne ikke hente faste mediciner."
                        : apiMessage;
                }

                return;
            }

            var medications = await response.Content.ReadFromJsonAsync<List<FixedMedicationApiModel>>();

            EditFixedMedications = medications?
                .OrderBy(medication => medication.ScheduledTime)
                .Select(medication => new FixedMedicationInputModel
                {
                    FixedMedicationId = medication.FixedMedicationId,
                    Name = medication.Name,
                    Description = medication.Description,
                    ScheduledTimeText = NormalizeTimeForInput(medication.ScheduledTime),
                    IsActive = medication.IsActive
                })
                .ToList() ?? [];
        }
        catch (HttpRequestException)
        {
            EditErrorMessage = "Kunne ikke hente faste mediciner fra API'et.";
        }
        finally
        {
            IsLoadingEditFixedMedications = false;
        }
    }

    private void AddCreateFixedMedication()
    {
        CreateFixedMedications.Add(new FixedMedicationInputModel
        {
            IsActive = true
        });
    }

    private void RemoveCreateFixedMedication(int index)
    {
        if (index < 0 || index >= CreateFixedMedications.Count)
        {
            return;
        }

        CreateFixedMedications.RemoveAt(index);
    }

    private void AddEditFixedMedication()
    {
        EditFixedMedications.Add(new FixedMedicationInputModel
        {
            IsActive = true
        });
    }

    private void RemoveEditFixedMedication(int index)
    {
        if (index < 0 || index >= EditFixedMedications.Count)
        {
            return;
        }

        if (EditFixedMedications[index].FixedMedicationId.HasValue)
        {
            return;
        }

        EditFixedMedications.RemoveAt(index);
    }

    private async Task<List<string>> SaveCreateFixedMedicationsAsync(HttpClient client, int citizenId)
    {
        var errors = new List<string>();

        foreach (var medication in CreateFixedMedications.Where(HasAnyFixedMedicationInput))
        {
            if (!TryBuildFixedMedicationPayload(medication, out var payload, out var error))
            {
                errors.Add(error);
                continue;
            }

            using var response = await client.PostAsJsonAsync($"api/citizens/{citizenId}/fixed-medications", payload);

            if (!response.IsSuccessStatusCode)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                errors.Add(string.IsNullOrWhiteSpace(apiMessage)
                    ? $"Kunne ikke oprette fast medicin '{medication.Name}'."
                    : apiMessage);
            }
        }

        return errors;
    }

    private async Task<List<string>> SaveEditFixedMedicationsAsync(HttpClient client, int citizenId)
    {
        var errors = new List<string>();

        foreach (var medication in EditFixedMedications.Where(HasAnyFixedMedicationInput))
        {
            if (!TryBuildFixedMedicationPayload(medication, out var payload, out var error))
            {
                errors.Add(error);
                continue;
            }

            HttpResponseMessage response;

            if (medication.FixedMedicationId.HasValue)
            {
                response = await client.PutAsJsonAsync(
                    $"api/citizens/{citizenId}/fixed-medications/{medication.FixedMedicationId.Value}",
                    new
                    {
                        payload.Name,
                        payload.Description,
                        payload.ScheduledTime,
                        isActive = medication.IsActive
                    });
            }
            else
            {
                response = await client.PostAsJsonAsync($"api/citizens/{citizenId}/fixed-medications", payload);
            }

            using (response)
            {
                if (!response.IsSuccessStatusCode)
                {
                    var apiMessage = await response.Content.ReadAsStringAsync();
                    errors.Add(string.IsNullOrWhiteSpace(apiMessage)
                        ? $"Kunne ikke gemme fast medicin '{medication.Name}'."
                        : apiMessage);
                }
            }
        }

        return errors;
    }

    private static bool HasAnyFixedMedicationInput(FixedMedicationInputModel medication)
    {
        return !string.IsNullOrWhiteSpace(medication.Name)
            || !string.IsNullOrWhiteSpace(medication.Description)
            || !string.IsNullOrWhiteSpace(medication.ScheduledTimeText);
    }

    private static bool TryBuildFixedMedicationPayload(
        FixedMedicationInputModel medication,
        out FixedMedicationPayload payload,
        out string errorMessage)
    {
        payload = default;

        if (string.IsNullOrWhiteSpace(medication.Name))
        {
            errorMessage = "Fast medicin mangler navn.";
            return false;
        }

        if (!TimeOnly.TryParse(medication.ScheduledTimeText, out var scheduledTime))
        {
            errorMessage = $"Fast medicin '{medication.Name}' mangler gyldigt klokkeslæt.";
            return false;
        }

        payload = new FixedMedicationPayload(
            medication.Name.Trim(),
            medication.Description.Trim(),
            scheduledTime);

        errorMessage = string.Empty;
        return true;
    }

    private static string NormalizeTimeForInput(string scheduledTime)
    {
        if (TimeOnly.TryParse(scheduledTime, out var time))
        {
            return time.ToString("HH\\:mm");
        }

        if (DateTime.TryParse(scheduledTime, out var dateTime))
        {
            return dateTime.ToString("HH:mm");
        }

        return string.Empty;
    }

    private CreateCitizenFormModel CreateDefaultCreateModel()
    {
        return new CreateCitizenFormModel
        {
            DepartmentId = ResolveDepartmentId(AuthService.SelectedDepartment)
        };
    }

    private static int ResolveDepartmentId(string? departmentName)
    {
        var match = DepartmentOptions.FirstOrDefault(option =>
            string.Equals(option.Name, departmentName, StringComparison.OrdinalIgnoreCase));

        return match?.Id ?? DepartmentOptions[0].Id;
    }

    private static string GetDepartmentName(int departmentId)
    {
        return DepartmentOptions.FirstOrDefault(option => option.Id == departmentId)?.Name ?? $"Afdeling {departmentId}";
    }

    private static string GetTrafficLightLabel(int trafficLight)
    {
        return TrafficLightOptions.FirstOrDefault(option => option.Value == trafficLight)?.Label ?? trafficLight.ToString();
    }

