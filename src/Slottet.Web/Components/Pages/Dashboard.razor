@page "/app"
@implements IDisposable
@using System.Net
@using System.Net.Http.Json
@inject AuthService AuthService

<PageTitle>Overlapssystem</PageTitle>

<section class="overlap-shell">
    <header class="overlap-header">
        <div class="overlap-header-main">
            <div class="overlap-tags">
                <span class="overlap-tag">@AuthService.SelectedDepartment</span>
                <span class="overlap-tag overlap-tag-alt">@AuthService.SelectedShift</span>
                <span class="overlap-tag overlap-tag-muted">@SelectedDate.ToString("dd-MM-yyyy")</span>
            </div>
            <div>
                <h1>@AuthService.SelectedDepartment overlapsystem</h1>
                <p class="overlap-subtitle">Borgeroversigt for den valgte afdeling og vagt.</p>
            </div>
        </div>
        <aside class="overlap-shift-tasks" aria-live="polite">
            <div class="overlap-shift-tasks-header">
                <p class="overlap-shift-tasks-title">Vagtopgaver</p>
                <button type="button"
                        class="overlap-shift-tasks-add"
                        title="Opret vagtopgave"
                        aria-label="Opret vagtopgave"
                        @onclick="OpenCreateShiftTaskModal"
                        disabled="@(IsShiftTasksLoading || IsCreatingShiftTask || !DepartmentIds.ContainsKey(AuthService.SelectedDepartment))">
                    +
                </button>
            </div>
            @if (IsLoading || IsShiftTasksLoading)
            {
                <p class="overlap-shift-tasks-status">Indlæser opgaver...</p>
            }
            else if (!string.IsNullOrWhiteSpace(ShiftTasksErrorMessage))
            {
                <p class="overlap-shift-tasks-status overlap-shift-tasks-status-error">@ShiftTasksErrorMessage</p>
            }
            else if (ShiftTasks.Count == 0)
            {
                <p class="overlap-shift-tasks-status">Ingen opgaver på vagten.</p>
            }
            else
            {
                <ul class="overlap-shift-tasks-list">
                    @foreach (var shiftTask in ShiftTasks)
                    {
                        <li class="overlap-shift-task-item @(shiftTask.Status == 2 ? "done" : string.Empty)">
                            <span class="overlap-shift-task-description">@shiftTask.Description</span>
                            <div class="overlap-shift-task-actions">
                                <span class="overlap-shift-task-status">@GetShiftTaskStatusLabel(shiftTask.Status)</span>
                                <button type="button"
                                        class="overlap-shift-task-toggle"
                                        @onclick="() => ToggleShiftTaskStatusAsync(shiftTask)"
                                        disabled="@(!CanToggleShiftTask(shiftTask.Id))">
                                    @(shiftTask.Status == 2 ? "Genåbn" : "Færdig")
                                </button>
                            </div>
                        </li>
                    }
                </ul>
            }
        </aside>
    </header>

    <div class="overlap-toolbar">
        <label class="overlap-filter">
            <span>Dato</span>
            <input type="date" value="@SelectedDate.ToString("yyyy-MM-dd")" @onchange="HandleDateChangedAsync" />
        </label>
    </div>

    @if (!string.IsNullOrWhiteSpace(LoadErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@LoadErrorMessage</div>
    }
    else if (IsLoading)
    {
        <div class="overlap-status-card">
            <p>Indlæser borgere...</p>
        </div>
    }
    else if (Overview?.Citizens.Count is 0 or null)
    {
        <div class="overlap-status-card">
            <p>Der blev ikke fundet aktive borgere for den valgte afdeling og vagt.</p>
        </div>
    }
    else
    {
        <div class="overlap-grid">
            @foreach (var citizen in CitizenCards)
            {
                <section class="overlap-card">
                    <div class="overlap-card-indicator @GetTrafficLightClass(citizen.TrafficLight)"
                         title="@GetTrafficLightLabel(citizen.TrafficLight)"
                         aria-label="@GetTrafficLightLabel(citizen.TrafficLight)"></div>

                    <header class="overlap-card-header">
                        <p class="overlap-card-apartment">Lejlighed @citizen.ApartmentNumber</p>
                        <h2>@citizen.CitizenName</h2>
                    </header>

                    <div class="overlap-card-body">
                        <p class="overlap-card-line">
                            <span>Medicin</span>
                            <strong>@citizen.RegisteredMedications/@citizen.TotalMedications</strong>
                        </p>
                        <p class="overlap-card-line">
                            <span>Næste</span>
                            <strong class="@(citizen.IsNextMedicationOverdue ? "overlap-next-medication-overdue" : string.Empty)">@citizen.NextMedicationLabel</strong>
                        </p>
                        <p class="overlap-card-line">
                            <span>Hændelser</span>
                            <strong>@citizen.SpecialEventsCount</strong>
                        </p>
                        <p class="overlap-card-latest-event-label">Seneste hændelse</p>
                        <p class="overlap-card-latest-event" title="@citizen.LatestSpecialEventDescription">@citizen.LatestSpecialEventDescription</p>
                    </div>

                    <div class="overlap-card-spacer"></div>

                    <div class="overlap-card-bottom-row">
                        <div class="overlap-card-employees">
                            <p class="overlap-card-employees-label">Medarbejdere</p>
                            @if (citizen.EmployeeNames.Count == 0)
                            {
                                <p class="overlap-card-empty">Ingen tildelt</p>
                            }
                            else
                            {
                                <div class="overlap-card-employee-list">
                                    @foreach (var employeeName in citizen.EmployeeNames)
                                    {
                                        <span class="overlap-card-employee">@employeeName</span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="overlap-card-actions">
                            <button type="button"
                                    class="overlap-expand-button"
                                    @onclick="() => OpenCitizenModal(citizen.CitizenId)">
                                <span aria-hidden="true">↗</span>
                                <span class="visually-hidden">Åbn @citizen.CitizenName</span>
                            </button>
                        </div>
                    </div>
                </section>
            }
        </div>
    }
</section>

@if (IsCreateShiftTaskModalOpen)
{
    <div class="modal fade show d-block overlap-modal-backdrop" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content overlap-modal overlap-shift-task-create-modal">
                <div class="modal-header overlap-modal-header">
                    <h2 class="modal-title h5 mb-0">Opret vagtopgave</h2>
                    <button type="button"
                            class="btn-close"
                            aria-label="Close"
                            @onclick="CloseCreateShiftTaskModal"
                            disabled="@IsCreatingShiftTask"></button>
                </div>
                <div class="modal-body overlap-modal-body">
                    @if (!string.IsNullOrWhiteSpace(CreateShiftTaskErrorMessage))
                    {
                        <div class="alert alert-danger mb-0" role="alert">@CreateShiftTaskErrorMessage</div>
                    }
                    <div class="overlap-modal-field">
                        <label for="create-shift-task-shift">Vagt</label>
                        <InputSelect id="create-shift-task-shift"
                                     class="form-select"
                                     @bind-Value="NewShiftTaskShiftType"
                                     disabled="@(IsCreatingShiftTask || NewShiftTaskForAllShifts)">
                            @foreach (var option in ShiftTypeOptions)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="form-check">
                        <InputCheckbox id="create-shift-task-all-shifts"
                                       class="form-check-input"
                                       @bind-Value="NewShiftTaskForAllShifts"
                                       disabled="@IsCreatingShiftTask" />
                        <label class="form-check-label" for="create-shift-task-all-shifts">
                            Vis på alle vagter
                        </label>
                    </div>
                    <div class="overlap-modal-field">
                        <label for="create-shift-task-description">Beskrivelse</label>
                        <InputText id="create-shift-task-description"
                                   class="form-control"
                                   @bind-Value="NewShiftTaskDescription"
                                   disabled="@IsCreatingShiftTask" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseCreateShiftTaskModal" disabled="@IsCreatingShiftTask">Annuller</button>
                    <button type="button" class="btn btn-primary" @onclick="CreateShiftTaskAsync" disabled="@IsCreatingShiftTask">
                        @(IsCreatingShiftTask ? "Opretter..." : "Opret")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (SelectedCitizen is not null)
{
    <div class="modal fade show d-block overlap-modal-backdrop" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content overlap-modal">
                <div class="modal-header overlap-modal-header">
                    <div>
                        <p class="overlap-modal-apartment">Lejlighed @SelectedCitizen.ApartmentNumber</p>
                        <h2 class="modal-title h4 mb-0">@SelectedCitizen.CitizenName</h2>
                    </div>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseCitizenModal" disabled="@IsSaving"></button>
                </div>

                <div class="modal-body overlap-modal-body">
                    @if (!string.IsNullOrWhiteSpace(SaveErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@SaveErrorMessage</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(SaveSuccessMessage))
                    {
                        <div class="alert alert-success" role="alert">@SaveSuccessMessage</div>
                    }

                    <section class="overlap-modal-section">
                        <div class="overlap-modal-indicator-row">
                            <span class="overlap-modal-label">Lyskrydsstatus</span>
                            <span class="overlap-modal-indicator @GetTrafficLightClass(SelectedCitizen.TrafficLight)"></span>
                        </div>
                        <div class="overlap-modal-field">
                            <label for="traffic-light-select">Skift status</label>
                            <InputSelect TValue="int"
                                         id="traffic-light-select"
                                         class="form-select"
                                         Value="SelectedCitizen.TrafficLight"
                                         ValueChanged="HandleSelectedCitizenTrafficLightChanged"
                                         ValueExpression="() => SelectedCitizen.TrafficLight"
                                         disabled="@(!CanEditTrafficLight || IsSaving)">
                                @foreach (var option in TrafficLightOptions)
                                {
                                    <option value="@option.Value">@option.Label</option>
                                }
                            </InputSelect>
                            @if (!CanEditTrafficLight)
                            {
                                <small class="text-muted">Kun admin kan gemme ændring af lyskrydsstatus.</small>
                            }
                        </div>
                    </section>

                    <section class="overlap-modal-section">
                        <h3 class="overlap-modal-section-title">Medicin</h3>
                        @if (SelectedCitizen.Medications.Count == 0)
                        {
                            <p class="mb-0">Ingen medicin på denne vagt.</p>
                        }
                        else
                        {
                            <div class="overlap-medication-list">
                                @for (var index = 0; index < SelectedCitizen.Medications.Count; index++)
                                {
                                    var medication = SelectedCitizen.Medications[index];
                                    var inputId = $"medication-{medication.FixedMedicationId}-{index}";

                                    <label class="overlap-medication-item @(medication.IsRegistered ? "done" : string.Empty)" for="@inputId">
                                        <input id="@inputId"
                                               type="checkbox"
                                               @bind="medication.IsRegistered"
                                               disabled="@(IsSaving || !CanRegisterMedication)"
                                               @bind:event="onchange" />
                                        <div>
                                            <strong>@medication.Name</strong>
                                            <p>@medication.Description</p>
                                            <small>@FormatMedicationLine(medication)</small>
                                        </div>
                                    </label>
                                }
                            </div>
                        }
                        @if (!CanRegisterMedication)
                        {
                            <small class="text-muted">Din rolle kan ikke gemme medicinregistreringer.</small>
                        }
                    </section>

                    <section class="overlap-modal-section">
                        <h3 class="overlap-modal-section-title">Særlige hændelser</h3>
                        <div class="overlap-event-toolbar">
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary"
                                    @onclick="AddSpecialEvent"
                                    disabled="@(IsSaving || !CanManageSpecialEvents)">
                                Tilføj hændelse
                            </button>
                        </div>
                        @if (SelectedCitizen.SpecialEvents.Count == 0)
                        {
                            <p class="mb-0">Ingen hændelser på denne vagt.</p>
                        }
                        else
                        {
                            <div class="overlap-event-editor-list">
                                @foreach (var specialEvent in SelectedCitizen.SpecialEvents.OrderByDescending(item => item.EventTime))
                                {
                                    <div class="overlap-event-editor-item">
                                        <InputDate TValue="DateTime"
                                                   Type="InputDateType.DateTimeLocal"
                                                   class="form-control"
                                                   @bind-Value="specialEvent.EventTime"
                                                   disabled="@(IsSaving || !CanManageSpecialEvents)" />
                                        <InputText class="form-control"
                                                   @bind-Value="specialEvent.Description"
                                                   disabled="@(IsSaving || !CanManageSpecialEvents)" />
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                @onclick="() => RemoveSpecialEvent(specialEvent)"
                                                disabled="@(IsSaving || !CanManageSpecialEvents)">
                                            Slet
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        @if (!CanManageSpecialEvents)
                        {
                            <small class="text-muted">Din rolle kan ikke gemme særlige hændelser.</small>
                        }
                    </section>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseCitizenModal" disabled="@IsSaving">Luk</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveSelectedCitizenChangesAsync" disabled="@IsSaving">
                        @(IsSaving ? "Opdaterer..." : "Opdater")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .overlap-shell {
        padding: 2rem 0 3rem;
        color: #19352c;
    }

    .overlap-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(250px, 320px);
        gap: 1rem;
        align-items: start;
        margin-bottom: 1.6rem;
    }

    .overlap-header-main {
        display: grid;
        gap: 0.6rem;
    }

    .overlap-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .overlap-tag {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        background: #dceadf;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .overlap-tag-alt {
        background: #efe4d6;
    }

    .overlap-tag-muted {
        background: #e8ecea;
        color: #4b6358;
    }

    .overlap-header h1 {
        margin: 0;
    }

    .overlap-subtitle {
        margin: 0.2rem 0 0;
        color: #597166;
    }

    .overlap-shift-tasks {
        border: 1px solid #d8e2dc;
        border-radius: 0.9rem;
        padding: 0.8rem;
        background: #f8fbf9;
    }

    .overlap-shift-tasks-title {
        margin: 0;
        color: #365246;
        font-size: 0.74rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .overlap-shift-tasks-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .overlap-shift-tasks-add {
        width: 1.65rem;
        height: 1.65rem;
        border: 1px solid #bfd1c4;
        border-radius: 0.45rem;
        background: #ffffff;
        color: #284439;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        line-height: 1;
        font-weight: 700;
    }

    .overlap-shift-tasks-add:disabled {
        opacity: 0.55;
    }

    .overlap-shift-tasks-status {
        margin: 0.55rem 0 0;
        color: #4f6a5f;
        font-size: 0.82rem;
    }

    .overlap-shift-tasks-status-error {
        color: #b42318;
    }

    .overlap-shift-tasks-list {
        margin: 0.55rem 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.4rem;
        max-height: 165px;
        overflow-y: auto;
        padding-right: 0.2rem;
    }

    .overlap-shift-task-item {
        display: flex;
        justify-content: space-between;
        gap: 0.6rem;
        align-items: center;
        background: #ffffff;
        border: 1px solid #dbe6e0;
        border-radius: 0.65rem;
        padding: 0.45rem 0.55rem;
    }

    .overlap-shift-task-item.done {
        background: #edf6f0;
    }

    .overlap-shift-task-description {
        min-width: 0;
        color: #284439;
        font-size: 0.82rem;
        line-height: 1.25;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .overlap-shift-task-actions {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        flex-shrink: 0;
    }

    .overlap-shift-task-status {
        flex-shrink: 0;
        font-size: 0.72rem;
        font-weight: 700;
        color: #365246;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .overlap-shift-task-toggle {
        border: 1px solid #bfd1c4;
        border-radius: 0.45rem;
        background: #ffffff;
        color: #284439;
        font-size: 0.72rem;
        font-weight: 700;
        padding: 0.2rem 0.45rem;
        line-height: 1.2;
    }

    .overlap-shift-task-toggle:disabled {
        opacity: 0.55;
    }

    .overlap-toolbar {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.4rem;
    }

    .overlap-filter {
        display: grid;
        gap: 0.35rem;
        min-width: 220px;
        font-weight: 700;
    }

    .overlap-filter input {
        padding: 0.75rem 0.9rem;
        border: 1px solid #bfd1c4;
        border-radius: 0.85rem;
        background: #fff;
        color: #173126;
    }

    .overlap-status-card {
        padding: 1.2rem 1.3rem;
        border: 1px solid #d5e1da;
        border-radius: 1.1rem;
        background: #f8fbf9;
    }

    .overlap-status-card p {
        margin: 0;
    }

    .overlap-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 320px));
        gap: 1rem;
        align-items: start;
    }

    .overlap-card {
        position: relative;
        width: 320px;
        min-height: 285px;
        padding: 1rem;
        border: 1px solid #d8e2dc;
        border-radius: 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f4f7f5 100%);
        box-shadow: 0 10px 24px rgba(29, 58, 46, 0.08);
        display: flex;
        flex-direction: column;
    }

    .overlap-card-indicator,
    .overlap-modal-indicator {
        display: inline-flex;
        width: 14px;
        height: 14px;
        border-radius: 999px;
        border: 2px solid rgba(0, 0, 0, 0.08);
        flex-shrink: 0;
    }

    .traffic-light-green {
        background: #78d66b;
    }

    .traffic-light-yellow {
        background: #f2c94c;
    }

    .traffic-light-red {
        background: #eb5757;
    }

    .overlap-card-indicator {
        position: absolute;
        top: 1rem;
        right: 1rem;
    }

    .overlap-card-header {
        padding-right: 1.4rem;
    }

    .overlap-card-apartment,
    .overlap-modal-apartment {
        margin: 0 0 0.25rem;
        color: #647b70;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .overlap-card-header h2 {
        margin: 0;
        font-size: 1.02rem;
        line-height: 1.2;
    }

    .overlap-card-body {
        margin-top: 0.8rem;
        display: grid;
        gap: 0.35rem;
    }

    .overlap-card-line {
        margin: 0;
        display: flex;
        justify-content: space-between;
        font-size: 0.82rem;
        color: #3c584d;
    }

    .overlap-card-line strong {
        color: #19352c;
        max-width: 60%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .overlap-card-line strong.overlap-next-medication-overdue {
        color: #b42318;
    }

    .overlap-card-latest-event-label {
        margin: 0.2rem 0 0;
        color: #647b70;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .overlap-card-latest-event {
        margin: 0;
        font-size: 0.78rem;
        color: #3c584d;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .overlap-card-spacer {
        flex: 1;
    }

    .overlap-card-bottom-row {
        display: flex;
        align-items: flex-end;
        gap: 0.75rem;
        margin-top: 0.75rem;
        padding-top: 0.7rem;
        border-top: 1px solid #dde6e1;
    }

    .overlap-card-employees {
        min-width: 0;
        flex: 1;
    }

    .overlap-card-employees-label {
        margin: 0 0 0.45rem;
        color: #647b70;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .overlap-card-employee-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .overlap-card-employee {
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.5rem;
        border-radius: 999px;
        background: #e7efea;
        color: #284439;
        font-size: 0.74rem;
        font-weight: 600;
    }

    .overlap-card-empty {
        margin: 0;
        color: #7a9086;
        font-size: 0.78rem;
    }

    .overlap-card-actions {
        display: flex;
        justify-content: flex-end;
        flex-shrink: 0;
    }

    .overlap-expand-button {
        width: 2.35rem;
        height: 2.35rem;
        border: 1px solid #c7d7ce;
        border-radius: 0.8rem;
        background: #ffffff;
        color: #19352c;
        font-size: 1.1rem;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
    }

    .overlap-expand-button:hover {
        transform: translateY(-1px);
        border-color: #9db4a8;
        box-shadow: 0 8px 16px rgba(29, 58, 46, 0.12);
    }

    .overlap-modal-backdrop {
        background: rgba(16, 26, 21, 0.45);
    }

    .overlap-modal {
        border: 0;
        border-radius: 1rem;
        overflow: hidden;
    }

    .overlap-shift-task-create-modal {
        max-width: 520px;
    }

    .overlap-modal-header {
        align-items: start;
    }

    .overlap-modal-body {
        display: grid;
        gap: 1rem;
    }

    .overlap-modal-section {
        border: 1px solid #d7e1db;
        border-radius: 0.8rem;
        padding: 0.8rem;
        display: grid;
        gap: 0.8rem;
    }

    .overlap-modal-section-title {
        margin: 0;
        font-size: 1rem;
    }

    .overlap-modal-indicator-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.9rem 1rem;
        border-radius: 0.9rem;
        background: #f5f8f6;
    }

    .overlap-modal-label {
