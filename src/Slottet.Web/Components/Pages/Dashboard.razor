@code {
    private static readonly IReadOnlyDictionary<string, int> DepartmentIds = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
    {
        ["Slottet"] = 1,
        ["Skoven"] = 2
    };

    private static readonly IReadOnlyList<TrafficLightOption> TrafficLightOptions =
    [
        new(1, "Grøn"),
        new(2, "Gul"),
        new(3, "Rød")
    ];

    private static readonly IReadOnlyList<ShiftTypeOption> ShiftTypeOptions =
    [
        new(1, "Dag"),
        new(2, "Aften"),
        new(3, "Nat")
    ];

    private CitizenOverviewResponse? Overview { get; set; }
    private List<CitizenCardModel> CitizenCards { get; set; } = [];
    private List<ShiftTaskItemModel> ShiftTasks { get; set; } = [];
    private int? CurrentShiftId { get; set; }
    private CitizenDetailModel? SelectedCitizen { get; set; }
    private string? LoadErrorMessage { get; set; }
    private string? ShiftTasksErrorMessage { get; set; }
    private string? CreateShiftTaskErrorMessage { get; set; }
    private string? SaveErrorMessage { get; set; }
    private string? SaveSuccessMessage { get; set; }
    private bool IsLoading { get; set; }
    private bool IsShiftTasksLoading { get; set; }
    private bool IsCreateShiftTaskModalOpen { get; set; }
    private bool IsCreatingShiftTask { get; set; }
    private HashSet<int> UpdatingShiftTaskIds { get; } = [];
    private bool IsSaving { get; set; }
    private int NewShiftTaskShiftType { get; set; } = 1;
    private bool NewShiftTaskForAllShifts { get; set; }
    private string NewShiftTaskDescription { get; set; } = string.Empty;
    private DateTime SelectedDate { get; set; } = DateTime.Today;

    private bool CanEditTrafficLight => AuthService.CurrentUser?.Role == "Admin";
    private bool CanRegisterMedication => AuthService.CurrentUser?.Role is "Admin" or "Medarbejder";
    private bool CanManageSpecialEvents => AuthService.CurrentUser?.Role is "Admin" or "Medarbejder";

    protected override void OnInitialized()
    {
        AuthService.AuthenticationStateChanged += HandleAuthenticationStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadOverviewAsync();
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }

    private async void HandleAuthenticationStateChanged()
    {
        await LoadOverviewAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadOverviewAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            ResetState();
            return;
        }

        if (!DepartmentIds.TryGetValue(AuthService.SelectedDepartment, out var departmentId))
        {
            ResetState();
            LoadErrorMessage = "Den valgte afdeling kunne ikke oversættes til en gyldig overlapvisning.";
            return;
        }

        try
        {
            IsLoading = true;
            LoadErrorMessage = null;

            using var client = AuthService.CreateApiClient();
            var shiftType = ResolveShiftType(AuthService.SelectedShift);
            using var shiftResponse = await client.GetAsync(
                $"api/shifts/resolve?departmentId={departmentId}&date={SelectedDate:yyyy-MM-dd}&shiftType={shiftType}");

            if (shiftResponse.StatusCode == HttpStatusCode.NotFound)
            {
                ResetState();
                LoadErrorMessage = "Vagten blev ikke fundet for den valgte dato.";
                return;
            }

            if (!shiftResponse.IsSuccessStatusCode)
            {
                ResetState();
                LoadErrorMessage = "Kunne ikke finde vagt-id for den valgte dato.";
                return;
            }

            var resolvedShift = await shiftResponse.Content.ReadFromJsonAsync<ShiftLookupResponse>();
            var shiftId = resolvedShift?.ShiftId;
            CurrentShiftId = shiftId;

            if (shiftId is null)
            {
                ResetState();
                Overview = new CitizenOverviewResponse
                {
                    ShiftDate = SelectedDate,
                    Citizens = []
                };
                return;
            }

            await LoadShiftTasksAsync(client, shiftId.Value);

            using var response = await client.GetAsync($"api/overlap/departments/{departmentId}/shifts/{shiftId.Value}/citizens");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                ResetState();
                LoadErrorMessage = "Der findes endnu ikke overlapdata for den valgte afdeling og vagt.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                ResetState();
                LoadErrorMessage = "Overlapssystemet kunne ikke hente borgeroversigten.";
                return;
            }

            Overview = await response.Content.ReadFromJsonAsync<CitizenOverviewResponse>();
            CitizenCards = BuildCitizenCards(Overview);
            SelectedCitizen = null;
        }
        catch (TaskCanceledException)
        {
            ResetState();
            LoadErrorMessage = "Indlæsning af overlapssystemet tog for lang tid. Prøv igen.";
        }
        catch (HttpRequestException)
        {
            ResetState();
            LoadErrorMessage = "Kunne ikke hente overlapssystemet fra API'et.";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleDateChangedAsync(ChangeEventArgs args)
    {
        if (!DateTime.TryParse(args.Value?.ToString(), out var parsedDate))
        {
            return;
        }

        SelectedDate = parsedDate.Date;
        await LoadOverviewAsync();
    }

    private void OpenCitizenModal(int citizenId)
    {
        var sourceCitizen = Overview?.Citizens.FirstOrDefault(citizen => citizen.CitizenId == citizenId);

        if (sourceCitizen is null)
        {
            return;
        }

        SaveErrorMessage = null;
        SaveSuccessMessage = null;

        SelectedCitizen = new CitizenDetailModel
        {
            CitizenId = sourceCitizen.CitizenId,
            CitizenName = sourceCitizen.CitizenName,
            ApartmentNumber = sourceCitizen.ApartmentNumber,
            TrafficLight = sourceCitizen.TrafficLight,
            OriginalTrafficLight = sourceCitizen.TrafficLight,
            Medications = sourceCitizen.Medications
                .OrderBy(medication => medication.ScheduledTime)
                .ThenBy(medication => medication.Name, StringComparer.OrdinalIgnoreCase)
                .Select(medication => new MedicationItemModel
                {
                    FixedMedicationId = medication.FixedMedicationId,
                    MedicationRegistrationId = medication.MedicationRegistrationId,
                    MedicinType = medication.MedicinType,
                    Name = medication.Name,
                    Description = medication.Description,
                    ScheduledTime = medication.ScheduledTime,
                    RegistrationTime = medication.RegistrationTime,
                    IsRegistered = medication.IsRegistered,
                    InitiallyRegistered = medication.IsRegistered
                })
                .ToList(),
            SpecialEvents = sourceCitizen.SpecialEvents
                .OrderByDescending(specialEvent => specialEvent.EventTime)
                .Select(specialEvent => new SpecialEventItemModel
                {
                    Id = specialEvent.Id,
                    Description = specialEvent.Description,
                    EventTime = specialEvent.EventTime,
                    OriginalDescription = specialEvent.Description,
                    OriginalEventTime = specialEvent.EventTime
                })
                .ToList(),
            DeletedSpecialEventIds = []
        };
    }

    private void CloseCitizenModal()
    {
        if (IsSaving)
        {
            return;
        }

        SelectedCitizen = null;
        SaveErrorMessage = null;
        SaveSuccessMessage = null;
    }

    private Task HandleSelectedCitizenTrafficLightChanged(int trafficLight)
    {
        if (SelectedCitizen is null)
        {
            return Task.CompletedTask;
        }

        SelectedCitizen.TrafficLight = trafficLight;
        return Task.CompletedTask;
    }

    private void AddSpecialEvent()
    {
        if (SelectedCitizen is null || IsSaving || !CanManageSpecialEvents)
        {
            return;
        }

        SelectedCitizen.SpecialEvents.Add(new SpecialEventItemModel
        {
            Description = string.Empty,
            EventTime = DateTime.Now
        });
    }

    private void RemoveSpecialEvent(SpecialEventItemModel specialEvent)
    {
        if (SelectedCitizen is null || IsSaving || !CanManageSpecialEvents)
        {
            return;
        }

        if (specialEvent.Id > 0)
        {
            SelectedCitizen.DeletedSpecialEventIds.Add(specialEvent.Id);
        }

        SelectedCitizen.SpecialEvents.Remove(specialEvent);
    }

    private async Task SaveSelectedCitizenChangesAsync()
    {
        if (SelectedCitizen is null || Overview is null || !DepartmentIds.TryGetValue(AuthService.SelectedDepartment, out var departmentId))
        {
            return;
        }

        SaveErrorMessage = null;
        SaveSuccessMessage = null;
        IsSaving = true;

        var errors = new List<string>();

        try
        {
            using var client = AuthService.CreateApiClient();

            if (SelectedCitizen.TrafficLight != SelectedCitizen.OriginalTrafficLight)
            {
                if (!CanEditTrafficLight)
                {
                    errors.Add("Lyskrydsstatus kan kun gemmes af admin.");
                }
                else
                {
                    using var citizenUpdateResponse = await client.PutAsJsonAsync(
                        $"api/citizens/{SelectedCitizen.CitizenId}",
                        new
                        {
                            name = SelectedCitizen.CitizenName,
                            apartmentNumber = SelectedCitizen.ApartmentNumber,
                            trafficLight = SelectedCitizen.TrafficLight,
                            departmentId,
                            isActive = true
                        });

                    if (!citizenUpdateResponse.IsSuccessStatusCode)
                    {
                        errors.Add("Kunne ikke gemme lyskrydsstatus.");
                    }
                }
            }

            if (!CanRegisterMedication)
            {
                errors.Add("Din rolle kan ikke gemme medicinregistreringer.");
            }
            else if (Overview.ShiftId <= 0)
            {
                errors.Add("Vagt-id mangler. Kunne ikke gemme medicinregistrering.");
            }
            else
            {
                var removedMedicationRegistrations = SelectedCitizen.Medications
                    .Where(medication => medication.MedicationRegistrationId.HasValue && !medication.IsRegistered)
                    .ToList();

                foreach (var medication in removedMedicationRegistrations)
                {
                    using var deleteResponse = await client.DeleteAsync(
                        $"api/shifts/{Overview.ShiftId}/citizens/{SelectedCitizen.CitizenId}/medication-registrations/{medication.MedicationRegistrationId!.Value}");

                    if (!deleteResponse.IsSuccessStatusCode)
                    {
                        var apiMessage = await deleteResponse.Content.ReadAsStringAsync();
                        errors.Add(string.IsNullOrWhiteSpace(apiMessage)
                            ? $"Kunne ikke fjerne medicinregistrering for {medication.Name}."
                            : apiMessage);
                        break;
                    }
                }

                if (errors.Count == 0)
                {
                    var newMedicationRegistrations = SelectedCitizen.Medications
                        .Where(medication => medication.MedicationRegistrationId is null && medication.IsRegistered)
                        .ToList();

                    foreach (var medication in newMedicationRegistrations)
                    {
                        using var medicationResponse = await client.PostAsJsonAsync(
                            $"api/shifts/{Overview.ShiftId}/citizens/{SelectedCitizen.CitizenId}/medication-registrations",
                            new
                            {
                                medicinType = medication.MedicinType,
                                citizenFixedMedicationId = medication.FixedMedicationId,
                                registrationTime = DateTime.UtcNow
                            });

                        var apiMessage = await medicationResponse.Content.ReadAsStringAsync();

                        if (!medicationResponse.IsSuccessStatusCode)
                        {
                            errors.Add(string.IsNullOrWhiteSpace(apiMessage)
                                ? $"Kunne ikke gemme medicinregistrering for {medication.Name}."
                                : apiMessage);
                            break;
                        }
                    }
                }
            }

            if (!CanManageSpecialEvents)
            {
                errors.Add("Din rolle kan ikke gemme særlige hændelser.");
            }
            else if (Overview.ShiftId <= 0)
            {
                errors.Add("Vagt-id mangler. Kunne ikke gemme særlige hændelser.");
            }
            else if (errors.Count == 0)
            {
                if (SelectedCitizen.SpecialEvents.Any(specialEvent => string.IsNullOrWhiteSpace(specialEvent.Description)))
                {
                    errors.Add("Alle særlige hændelser skal have en beskrivelse.");
                }
                else
                {
                    foreach (var specialEventId in SelectedCitizen.DeletedSpecialEventIds.Distinct())
                    {
                        using var deleteSpecialEventResponse = await client.DeleteAsync(
                            $"api/shifts/{Overview.ShiftId}/citizens/{SelectedCitizen.CitizenId}/special-events/{specialEventId}");

                        if (!deleteSpecialEventResponse.IsSuccessStatusCode)
                        {
                            var apiMessage = await deleteSpecialEventResponse.Content.ReadAsStringAsync();
                            errors.Add(string.IsNullOrWhiteSpace(apiMessage)
                                ? "Kunne ikke slette en særlig hændelse."
                                : apiMessage);
                            break;
                        }
                    }

                    if (errors.Count == 0)
                    {
                        foreach (var specialEvent in SelectedCitizen.SpecialEvents.Where(specialEvent => specialEvent.Id <= 0))
                        {
                            using var createSpecialEventResponse = await client.PostAsJsonAsync(
                                $"api/shifts/{Overview.ShiftId}/citizens/{SelectedCitizen.CitizenId}/special-events",
                                new
                                {
                                    description = specialEvent.Description.Trim(),
                                    eventTime = specialEvent.EventTime
                                });

                            if (!createSpecialEventResponse.IsSuccessStatusCode)
                            {
                                var apiMessage = await createSpecialEventResponse.Content.ReadAsStringAsync();
                                errors.Add(string.IsNullOrWhiteSpace(apiMessage)
                                    ? "Kunne ikke oprette en særlig hændelse."
                                    : apiMessage);
                                break;
                            }
                        }
                    }

                    if (errors.Count == 0)
                    {
                        foreach (var specialEvent in SelectedCitizen.SpecialEvents.Where(specialEvent => specialEvent.Id > 0 && specialEvent.HasChanges()))
                        {
                            using var updateSpecialEventResponse = await client.PutAsJsonAsync(
                                $"api/shifts/{Overview.ShiftId}/citizens/{SelectedCitizen.CitizenId}/special-events/{specialEvent.Id}",
                                new
                                {
                                    description = specialEvent.Description.Trim(),
                                    eventTime = specialEvent.EventTime
                                });

                            if (!updateSpecialEventResponse.IsSuccessStatusCode)
                            {
                                var apiMessage = await updateSpecialEventResponse.Content.ReadAsStringAsync();
                                errors.Add(string.IsNullOrWhiteSpace(apiMessage)
                                    ? "Kunne ikke opdatere en særlig hændelse."
                                    : apiMessage);
                                break;
                            }
                        }
                    }
                }
            }

            if (errors.Count > 0)
            {
                SaveErrorMessage = string.Join(" ", errors.Distinct(StringComparer.OrdinalIgnoreCase));
                return;
            }

            SaveSuccessMessage = "Ændringerne er opdateret.";
            await LoadOverviewAsync();
            SelectedCitizen = null;
        }
        catch (TaskCanceledException)
        {
            SaveErrorMessage = "Opdatering tog for lang tid. Prøv igen.";
        }
        catch (HttpRequestException)
        {
            SaveErrorMessage = "Kunne ikke opdatere data via API'et.";
        }
        catch (Exception)
        {
            SaveErrorMessage = "Der opstod en ukendt fejl ved gem.";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void ResetState()
    {
        Overview = null;
        CitizenCards = [];
        ShiftTasks = [];
        CurrentShiftId = null;
        ShiftTasksErrorMessage = null;
        CreateShiftTaskErrorMessage = null;
        IsCreateShiftTaskModalOpen = false;
        IsCreatingShiftTask = false;
        UpdatingShiftTaskIds.Clear();
        NewShiftTaskShiftType = ResolveShiftType(AuthService.SelectedShift);
        NewShiftTaskForAllShifts = false;
        NewShiftTaskDescription = string.Empty;
        SelectedCitizen = null;
        LoadErrorMessage = null;
    }

    private async Task LoadShiftTasksAsync(HttpClient client, int shiftId)
    {
        IsShiftTasksLoading = true;
        ShiftTasksErrorMessage = null;

        try
        {
            using var response = await client.GetAsync($"api/shifts/{shiftId}/tasks");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                ShiftTasks = [];
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                ShiftTasks = [];
                ShiftTasksErrorMessage = "Kunne ikke hente vagtopgaver.";
                return;
            }

            ShiftTasks = await response.Content.ReadFromJsonAsync<List<ShiftTaskItemModel>>() ?? [];
        }
        catch (TaskCanceledException)
        {
            ShiftTasks = [];
            ShiftTasksErrorMessage = "Indlæsning af vagtopgaver tog for lang tid.";
        }
        catch (HttpRequestException)
        {
            ShiftTasks = [];
            ShiftTasksErrorMessage = "Kunne ikke hente vagtopgaver fra API'et.";
        }
        finally
        {
            IsShiftTasksLoading = false;
        }
    }

    private void OpenCreateShiftTaskModal()
    {
        if (!DepartmentIds.ContainsKey(AuthService.SelectedDepartment) || IsShiftTasksLoading || IsCreatingShiftTask)
        {
            return;
        }

        NewShiftTaskDescription = string.Empty;
        NewShiftTaskShiftType = ResolveShiftType(AuthService.SelectedShift);
        NewShiftTaskForAllShifts = false;
        CreateShiftTaskErrorMessage = null;
        IsCreateShiftTaskModalOpen = true;
    }

    private void CloseCreateShiftTaskModal()
    {
        if (IsCreatingShiftTask)
        {
            return;
        }

        IsCreateShiftTaskModalOpen = false;
        CreateShiftTaskErrorMessage = null;
        NewShiftTaskDescription = string.Empty;
        NewShiftTaskShiftType = ResolveShiftType(AuthService.SelectedShift);
        NewShiftTaskForAllShifts = false;
    }

    private async Task CreateShiftTaskAsync()
    {
        if (!DepartmentIds.TryGetValue(AuthService.SelectedDepartment, out var departmentId))
        {
            CreateShiftTaskErrorMessage = "Kunne ikke finde den aktuelle afdeling.";
            return;
        }

        if (string.IsNullOrWhiteSpace(NewShiftTaskDescription))
        {
            CreateShiftTaskErrorMessage = "Beskrivelse er påkrævet.";
            return;
        }

        IsCreatingShiftTask = true;
        CreateShiftTaskErrorMessage = null;

        try
        {
            using var client = AuthService.CreateApiClient();
            var requestedShiftTypes = NewShiftTaskForAllShifts
                ? ShiftTypeOptions.Select(option => option.Value).Distinct().ToList()
                : [NewShiftTaskShiftType];
            var resolvedShiftIds = new List<int>();

            foreach (var shiftType in requestedShiftTypes)
            {
                using var shiftResponse = await client.GetAsync(
                    $"api/shifts/resolve?departmentId={departmentId}&date={SelectedDate:yyyy-MM-dd}&shiftType={shiftType}");

                if (!shiftResponse.IsSuccessStatusCode)
                {
                    continue;
                }

                var resolvedShift = await shiftResponse.Content.ReadFromJsonAsync<ShiftLookupResponse>();

                if (resolvedShift?.ShiftId > 0)
                {
                    resolvedShiftIds.Add(resolvedShift.ShiftId);
                }
            }

            var targetShiftIds = resolvedShiftIds.Distinct().ToList();

            if (targetShiftIds.Count == 0)
            {
                CreateShiftTaskErrorMessage = "Kunne ikke finde vagt(er) for valget.";
                return;
            }

            var createdShiftIds = new List<int>();

            foreach (var targetShiftId in targetShiftIds)
            {
                using var response = await client.PostAsJsonAsync(
                    $"api/shifts/{targetShiftId}/tasks",
                    new { description = NewShiftTaskDescription.Trim() });

                if (!response.IsSuccessStatusCode)
                {
                    continue;
                }

                createdShiftIds.Add(targetShiftId);
            }

            if (createdShiftIds.Count == 0)
            {
                CreateShiftTaskErrorMessage = "Kunne ikke oprette vagtopgaven.";
                return;
            }

            if (CurrentShiftId is not null && createdShiftIds.Contains(CurrentShiftId.Value))
            {
                await LoadShiftTasksAsync(client, CurrentShiftId.Value);
            }

            IsCreateShiftTaskModalOpen = false;
            NewShiftTaskDescription = string.Empty;
            NewShiftTaskShiftType = ResolveShiftType(AuthService.SelectedShift);
            NewShiftTaskForAllShifts = false;
        }
        catch (TaskCanceledException)
        {
            CreateShiftTaskErrorMessage = "Oprettelse af vagtopgave tog for lang tid.";
        }
        catch (HttpRequestException)
        {
            CreateShiftTaskErrorMessage = "Kunne ikke oprette vagtopgave via API'et.";
        }
        finally
        {
            IsCreatingShiftTask = false;
        }
    }

    private bool CanToggleShiftTask(int shiftTaskId)
    {
        return CurrentShiftId is not null
               && !IsShiftTasksLoading
               && !IsCreatingShiftTask
               && !UpdatingShiftTaskIds.Contains(shiftTaskId);
    }

    private async Task ToggleShiftTaskStatusAsync(ShiftTaskItemModel shiftTask)
    {
        if (CurrentShiftId is null || !CanToggleShiftTask(shiftTask.Id))
        {
            return;
        }

        UpdatingShiftTaskIds.Add(shiftTask.Id);
        ShiftTasksErrorMessage = null;
        var newStatus = shiftTask.Status == 2 ? 1 : 2;

        try
        {
            using var client = AuthService.CreateApiClient();
            using var response = await client.PutAsJsonAsync(
                $"api/shifts/{CurrentShiftId.Value}/tasks/{shiftTask.Id}",
                new
                {
                    description = shiftTask.Description,
                    status = newStatus
                });

            if (!response.IsSuccessStatusCode)
            {
                var apiMessage = await response.Content.ReadAsStringAsync();
                ShiftTasksErrorMessage = string.IsNullOrWhiteSpace(apiMessage)
                    ? "Kunne ikke opdatere vagtopgaven."
                    : apiMessage;
                return;
            }

            await LoadShiftTasksAsync(client, CurrentShiftId.Value);
        }
        catch (TaskCanceledException)
        {
            ShiftTasksErrorMessage = "Opdatering af vagtopgave tog for lang tid.";
        }
        catch (HttpRequestException)
        {
            ShiftTasksErrorMessage = "Kunne ikke opdatere vagtopgave via API'et.";
        }
        finally
        {
            UpdatingShiftTaskIds.Remove(shiftTask.Id);
        }
    }

    private List<CitizenCardModel> BuildCitizenCards(CitizenOverviewResponse? overview)
    {
        if (overview?.Citizens is null)
        {
            return [];
        }

        return overview.Citizens
            .OrderBy(citizen => GetApartmentSortValue(citizen.ApartmentNumber))
            .ThenBy(citizen => citizen.ApartmentNumber, StringComparer.OrdinalIgnoreCase)
            .ThenBy(citizen => citizen.CitizenName, StringComparer.OrdinalIgnoreCase)
            .Select(citizen =>
            {
                var registeredCount = citizen.Medications.Count(medication => medication.IsRegistered);
                var sortedMedications = citizen.Medications
                    .OrderBy(medication => medication.ScheduledTime)
                    .ToList();
                var now = DateTime.Now;
                var overdueMedication = sortedMedications
                    .FirstOrDefault(medication => !medication.IsRegistered && medication.ScheduledTime <= now);
                var nextUpcomingMedication = sortedMedications
                    .FirstOrDefault(medication => !medication.IsRegistered && medication.ScheduledTime > now);
                var nextMedication = overdueMedication ?? nextUpcomingMedication;
                var isNextMedicationOverdue = overdueMedication is not null;
                var latestSpecialEventDescription = citizen.SpecialEvents
                    .OrderByDescending(specialEvent => specialEvent.EventTime)
                    .Select(specialEvent => specialEvent.Description)
                    .FirstOrDefault();

                return new CitizenCardModel
                {
                    CitizenId = citizen.CitizenId,
                    CitizenName = citizen.CitizenName,
                    TrafficLight = citizen.TrafficLight,
                    ApartmentNumber = citizen.ApartmentNumber,
                    EmployeeNames = citizen.AssignedEmployees
                        .OrderBy(employee => employee.Name, StringComparer.OrdinalIgnoreCase)
                        .Select(employee => employee.Name)
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .ToList(),
                    RegisteredMedications = registeredCount,
                    TotalMedications = citizen.Medications.Count,
                    NextMedicationLabel = nextMedication is null
                        ? "-"
                        : $"{nextMedication.ScheduledTime:HH:mm} {nextMedication.Name}",
                    IsNextMedicationOverdue = isNextMedicationOverdue,
                    SpecialEventsCount = citizen.SpecialEvents.Count,
                    LatestSpecialEventDescription = string.IsNullOrWhiteSpace(latestSpecialEventDescription)
                        ? "Ingen hændelser"
                        : latestSpecialEventDescription
                };
            })
            .ToList();
    }

    private static string FormatMedicationLine(MedicationItemModel medication)
    {
        var planned = medication.ScheduledTime.ToString("HH:mm");
        var status = medication.IsRegistered
            ? $"Registreret {medication.RegistrationTime?.ToString("HH:mm") ?? string.Empty}".Trim()
            : "Ikke registreret";
        return $"{planned} • {status}";
    }

    private static int ResolveShiftType(string selectedShift)
    {
        return selectedShift switch
        {
            "Dag" => 1,
            "Aften" => 2,
            "Nat" => 3,
            _ => 1
        };
    }

    private static int GetApartmentSortValue(string apartmentNumber)
    {
        return int.TryParse(apartmentNumber, out var parsedValue)
            ? parsedValue
            : int.MaxValue;
    }

    private static string GetTrafficLightClass(int trafficLight)
    {
        return trafficLight switch
        {
            1 => "traffic-light-green",
            2 => "traffic-light-yellow",
            3 => "traffic-light-red",
            _ => "traffic-light-green"
        };
    }

    private static string GetTrafficLightLabel(int trafficLight)
    {
        return trafficLight switch
        {
            1 => "Grøn",
            2 => "Gul",
            3 => "Rød",
            _ => "Ukendt"
        };
    }

    private static string GetShiftTaskStatusLabel(int status)
    {
        return status switch
        {
            2 => "Færdig",
            _ => "Åben"
        };
    }

