@page "/app"
@implements IDisposable
@using System.Net
@using System.Net.Http.Json
@inject AuthService AuthService

<PageTitle>Overlapssystem</PageTitle>

<section class="overlap-shell">
    <header class="overlap-header">
        <div class="overlap-tags">
            <span class="overlap-tag">@AuthService.SelectedDepartment</span>
            <span class="overlap-tag overlap-tag-alt">@AuthService.SelectedShift</span>
            @if (Overview?.ShiftDate is not null)
            {
                <span class="overlap-tag overlap-tag-muted">@Overview.ShiftDate.ToString("dd-MM-yyyy")</span>
            }
        </div>
        <div>
            <h1>@AuthService.SelectedDepartment overlapsystem</h1>
            <p class="overlap-subtitle">Borgeroversigt for den valgte afdeling og vagt.</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(LoadErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@LoadErrorMessage</div>
    }
    else if (IsLoading)
    {
        <div class="overlap-status-card">
            <p>Indlæser borgere...</p>
        </div>
    }
    else if (Overview?.Citizens.Count is 0 or null)
    {
        <div class="overlap-status-card">
            <p>Der blev ikke fundet aktive borgere for den valgte afdeling og vagt.</p>
        </div>
    }
    else
    {
        <div class="overlap-grid">
            @foreach (var citizen in CitizenCards)
            {
                <section class="overlap-card">
                    <div class="overlap-card-indicator @GetTrafficLightClass(citizen.TrafficLight)"
                         title="@GetTrafficLightLabel(citizen.TrafficLight)"
                         aria-label="@GetTrafficLightLabel(citizen.TrafficLight)"></div>

                    <header class="overlap-card-header">
                        <p class="overlap-card-apartment">Lejlighed @citizen.ApartmentNumber</p>
                        <h2>@citizen.CitizenName</h2>
                    </header>

                    <div class="overlap-card-spacer"></div>

                    <div class="overlap-card-actions">
                        <button type="button"
                                class="overlap-expand-button"
                                @onclick="() => OpenCitizenModal(citizen)">
                            <span aria-hidden="true">↗</span>
                            <span class="visually-hidden">Åbn @citizen.CitizenName</span>
                        </button>
                    </div>
                </section>
            }
        </div>
    }
</section>

@if (SelectedCitizen is not null)
{
    <div class="modal fade show d-block overlap-modal-backdrop" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content overlap-modal">
                <div class="modal-header overlap-modal-header">
                    <div>
                        <p class="overlap-modal-apartment">Lejlighed @SelectedCitizen.ApartmentNumber</p>
                        <h2 class="modal-title h4 mb-0">@SelectedCitizen.CitizenName</h2>
                    </div>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseCitizenModal"></button>
                </div>

                <div class="modal-body overlap-modal-body">
                    <div class="overlap-modal-indicator-row">
                        <span class="overlap-modal-label">Lyskrydsstatus</span>
                        <span class="overlap-modal-indicator @GetTrafficLightClass(SelectedCitizen.TrafficLight)"></span>
                    </div>

                    <div class="overlap-modal-field">
                        <label for="traffic-light-select">Skift status</label>
                        <InputSelect TValue="int"
                                     id="traffic-light-select"
                                     class="form-select"
                                     Value="SelectedCitizen.TrafficLight"
                                     ValueChanged="@(value => HandleSelectedCitizenTrafficLightChanged(value))"
                                     ValueExpression="() => SelectedCitizen.TrafficLight">
                            @foreach (var option in TrafficLightOptions)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseCitizenModal">Luk</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .overlap-shell {
        padding: 2rem 0 3rem;
        color: #19352c;
    }

    .overlap-header {
        display: grid;
        gap: 0.6rem;
        margin-bottom: 1.6rem;
    }

    .overlap-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .overlap-tag {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        background: #dceadf;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .overlap-tag-alt {
        background: #efe4d6;
    }

    .overlap-tag-muted {
        background: #e8ecea;
        color: #4b6358;
    }

    .overlap-header h1 {
        margin: 0;
    }

    .overlap-subtitle {
        margin: 0.2rem 0 0;
        color: #597166;
    }

    .overlap-status-card {
        padding: 1.2rem 1.3rem;
        border: 1px solid #d5e1da;
        border-radius: 1.1rem;
        background: #f8fbf9;
    }

    .overlap-status-card p {
        margin: 0;
    }

    .overlap-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 240px));
        gap: 1rem;
        align-items: start;
    }

    .overlap-card {
        position: relative;
        width: 240px;
        height: 160px;
        padding: 1rem;
        border: 1px solid #d8e2dc;
        border-radius: 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f4f7f5 100%);
        box-shadow: 0 10px 24px rgba(29, 58, 46, 0.08);
        display: flex;
        flex-direction: column;
    }

    .overlap-card-indicator,
    .overlap-modal-indicator {
        display: inline-flex;
        width: 14px;
        height: 14px;
        border-radius: 999px;
        border: 2px solid rgba(0, 0, 0, 0.08);
        flex-shrink: 0;
    }

    .traffic-light-green {
        background: #78d66b;
    }

    .traffic-light-yellow {
        background: #f2c94c;
    }

    .traffic-light-red {
        background: #eb5757;
    }

    .overlap-card-indicator {
        position: absolute;
        top: 1rem;
        right: 1rem;
    }

    .overlap-card-header {
        padding-right: 1.4rem;
    }

    .overlap-card-apartment,
    .overlap-modal-apartment {
        margin: 0 0 0.25rem;
        color: #647b70;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .overlap-card-header h2 {
        margin: 0;
        font-size: 1.02rem;
        line-height: 1.2;
    }

    .overlap-card-spacer {
        flex: 1;
    }

    .overlap-card-actions {
        display: flex;
        justify-content: flex-end;
    }

    .overlap-expand-button {
        width: 2.35rem;
        height: 2.35rem;
        border: 1px solid #c7d7ce;
        border-radius: 0.8rem;
        background: #ffffff;
        color: #19352c;
        font-size: 1.1rem;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
    }

    .overlap-expand-button:hover {
        transform: translateY(-1px);
        border-color: #9db4a8;
        box-shadow: 0 8px 16px rgba(29, 58, 46, 0.12);
    }

    .overlap-modal-backdrop {
        background: rgba(16, 26, 21, 0.45);
    }

    .overlap-modal {
        border: 0;
        border-radius: 1rem;
        overflow: hidden;
    }

    .overlap-modal-header {
        align-items: start;
    }

    .overlap-modal-body {
        display: grid;
        gap: 1rem;
    }

    .overlap-modal-indicator-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.9rem 1rem;
        border-radius: 0.9rem;
        background: #f5f8f6;
    }

    .overlap-modal-label {
        font-weight: 700;
        color: #365246;
    }

    .overlap-modal-field {
        display: grid;
        gap: 0.4rem;
    }

    .overlap-modal-field label {
        font-weight: 700;
        color: #365246;
    }

    @@media (max-width: 640px) {
        .overlap-grid {
            grid-template-columns: 1fr;
            justify-items: stretch;
        }

        .overlap-card {
            width: 100%;
        }
    }
</style>

@code {
    private static readonly IReadOnlyDictionary<string, int> DepartmentIds = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
    {
        ["Slottet"] = 1,
        ["Skoven"] = 2
    };

    private static readonly IReadOnlyDictionary<string, int> ShiftIds = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
    {
        ["Dag"] = 1,
        ["Aften"] = 2,
        ["Nat"] = 3
    };

    private static readonly IReadOnlyList<TrafficLightOption> TrafficLightOptions =
    [
        new(1, "Grøn"),
        new(2, "Gul"),
        new(3, "Rød")
    ];

    private CitizenOverviewResponse? Overview { get; set; }
    private List<CitizenCardModel> CitizenCards { get; set; } = [];
    private CitizenCardModel? SelectedCitizen { get; set; }
    private string? LoadErrorMessage { get; set; }
    private bool IsLoading { get; set; }

    protected override void OnInitialized()
    {
        AuthService.AuthenticationStateChanged += HandleAuthenticationStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadOverviewAsync();
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }

    private async void HandleAuthenticationStateChanged()
    {
        await LoadOverviewAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadOverviewAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Overview = null;
            CitizenCards = [];
            SelectedCitizen = null;
            LoadErrorMessage = null;
            IsLoading = false;
            return;
        }

        if (!DepartmentIds.TryGetValue(AuthService.SelectedDepartment, out var departmentId)
            || !ShiftIds.TryGetValue(AuthService.SelectedShift, out var shiftId))
        {
            Overview = null;
            CitizenCards = [];
            SelectedCitizen = null;
            LoadErrorMessage = "Den valgte afdeling eller vagt kunne ikke oversættes til en gyldig overlapvisning.";
            IsLoading = false;
            return;
        }

        try
        {
            IsLoading = true;
            LoadErrorMessage = null;

            using var client = AuthService.CreateApiClient();
            using var response = await client.GetAsync($"api/overlap/departments/{departmentId}/shifts/{shiftId}/citizens");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                Overview = null;
                CitizenCards = [];
                SelectedCitizen = null;
                LoadErrorMessage = "Der findes endnu ikke overlapdata for den valgte afdeling og vagt.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                Overview = null;
                CitizenCards = [];
                SelectedCitizen = null;
                LoadErrorMessage = "Overlapssystemet kunne ikke hente borgeroversigten.";
                return;
            }

            Overview = await response.Content.ReadFromJsonAsync<CitizenOverviewResponse>();
            CitizenCards = Overview?.Citizens
                .OrderBy(citizen => citizen.ApartmentNumber, StringComparer.OrdinalIgnoreCase)
                .ThenBy(citizen => citizen.CitizenName, StringComparer.OrdinalIgnoreCase)
                .ToList() ?? [];
            SelectedCitizen = null;
        }
        catch (TaskCanceledException)
        {
            Overview = null;
            CitizenCards = [];
            SelectedCitizen = null;
            LoadErrorMessage = "Indlæsning af overlapssystemet tog for lang tid. Prøv igen.";
        }
        catch (HttpRequestException)
        {
            Overview = null;
            CitizenCards = [];
            SelectedCitizen = null;
            LoadErrorMessage = "Kunne ikke hente overlapssystemet fra API'et.";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OpenCitizenModal(CitizenCardModel citizen)
    {
        SelectedCitizen = new CitizenCardModel
        {
            CitizenId = citizen.CitizenId,
            CitizenName = citizen.CitizenName,
            ApartmentNumber = citizen.ApartmentNumber,
            TrafficLight = citizen.TrafficLight
        };
    }

    private void CloseCitizenModal()
    {
        SelectedCitizen = null;
    }

    private Task HandleSelectedCitizenTrafficLightChanged(int trafficLight)
    {
        if (SelectedCitizen is null)
        {
            return Task.CompletedTask;
        }

        SelectedCitizen.TrafficLight = trafficLight;

        var card = CitizenCards.FirstOrDefault(citizen => citizen.CitizenId == SelectedCitizen.CitizenId);

        if (card is not null)
        {
            card.TrafficLight = trafficLight;
        }

        return Task.CompletedTask;
    }

    private static string GetTrafficLightClass(int trafficLight)
    {
        return trafficLight switch
        {
            1 => "traffic-light-green",
            2 => "traffic-light-yellow",
            3 => "traffic-light-red",
            _ => "traffic-light-green"
        };
    }

    private static string GetTrafficLightLabel(int trafficLight)
    {
        return trafficLight switch
        {
            1 => "Grøn",
            2 => "Gul",
            3 => "Rød",
            _ => "Ukendt"
        };
    }

    private sealed record TrafficLightOption(int Value, string Label);

    private sealed class CitizenOverviewResponse
    {
        public DateTime ShiftDate { get; set; }
        public List<CitizenCardModel> Citizens { get; set; } = [];
    }

    private sealed class CitizenCardModel
    {
        public int CitizenId { get; set; }
        public string CitizenName { get; set; } = string.Empty;
        public int TrafficLight { get; set; }
        public string ApartmentNumber { get; set; } = string.Empty;
    }
}
