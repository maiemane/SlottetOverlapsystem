@page "/admin/opret-medarbejder"
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<PageTitle>Opret Medarbejder</PageTitle>

@if (IsAdmin)
{
    <section class="p-4">
        <h1>Opret Medarbejder</h1>
    </section>
}

@code {
    private bool IsAdmin => AuthService.CurrentUser?.Role == "Admin";

    protected override void OnInitialized()
    {
        if (!IsAdmin)
        {
            NavigationManager.NavigateTo("/app", replace: true);
        }
    }
}
