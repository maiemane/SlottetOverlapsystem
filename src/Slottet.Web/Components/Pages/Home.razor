@page "/"
@inject NavigationManager NavigationManager
@inject AuthService AuthService

<PageTitle>Login</PageTitle>

<div class="login-shell">
    <section class="login-panel">
        <h1>Slottet/Skoven overlapsystem</h1>

        <EditForm FormName="login-form" class="login-form" Model="@LoginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="login-error">@ErrorMessage</div>
            }

            <div class="login-field">
                <label for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="LoginModel.Email" />
                <ValidationMessage For="() => LoginModel.Email" />
            </div>

            <div class="login-field">
                <label for="password">Password</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="LoginModel.Password" />
                <ValidationMessage For="() => LoginModel.Password" />
            </div>

            <button type="submit" class="login-submit">Log ind</button>
        </EditForm>

        <div class="test-logins">
            <div class="test-login-card">
                <strong>Medarbejder</strong>
                <span>medarbejder@slottet.dk</span>
                <span>med123</span>
            </div>

            <div class="test-login-card">
                <strong>Admin</strong>
                <span>admin@slottet.dk</span>
                <span>admin123</span>
            </div>
        </div>
    </section>
</div>

@code {
    [SupplyParameterFromForm(FormName = "login-form")]
    private LoginFormModel LoginModel { get; set; } = new();

    private string? ErrorMessage { get; set; }

    protected override void OnInitialized()
    {
        if (AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/app", replace: true);
        }
    }

    private async Task HandleLogin()
    {
        var result = await AuthService.LoginAsync(LoginModel.Email, LoginModel.Password);

        if (result.IsSuccess)
        {
            ErrorMessage = null;
            NavigationManager.NavigateTo("/app", replace: true);
            return;
        }

        ErrorMessage = result.ErrorMessage;
    }
}
