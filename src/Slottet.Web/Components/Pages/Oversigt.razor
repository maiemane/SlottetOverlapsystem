@page "/oversigt"
@page "/oversigt/{valg}"

<PageTitle>Oversigt</PageTitle>

<h3>@(string.IsNullOrEmpty(valg) ? "Vælg en oversigt" : $"Oversigt: {valg}")</h3>

@if (string.IsNullOrEmpty(valg))
{
    <p>Ingen valg modtaget. Gå til <a href="/menu">Menu</a> for at vælge en vej.</p>
}
else
{
    <p>Vis indhold for: <strong>@valg</strong></p>
}

@code {
    [Parameter]
    public string? valg { get; set; }
}